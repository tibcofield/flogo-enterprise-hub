{
  "name": "openai-file-list",
  "version": "1.0.0",
  "type": "flogo:activity",
  "title": "File List",
  "author": "TIBCO Software",
  "ref": "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/fileList",
  "display": {
    "category": "openAI",
    "visible": true,
    "description": "This activity lists files in OpenAI file storage with support for filtering by purpose and pagination",
    "smallIcon": "icons/openAPISmall.png",
    "largeIcon": "icons/openAPILarge.png"
  },
  "feature": {
    "retry": {
      "enabled": true
    }
  },
  "settings": [
    {
      "name": "endPointURL",
      "type": "string",
      "required": true,
      "display": {
        "name": "API Endpoint URL",
        "description": "Endpoint URL for the OpenAI API, for example https://api.openai.com/v1",
        "appPropertySupport": true
      }
    },
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "display": {
        "name": "OpenAI API Key",
        "description": "OpenAI API key that is required to authenticate with the OpenAI API",
        "appPropertySupport": true
      }
    }
  ],
  "inputs": [
    {
      "name": "limit",
      "type": "integer",
      "required": false
    },
    {
      "name": "purpose",
      "type": "string",
      "required": false
    },
    {
      "name": "order",
      "type": "string",
      "required": false
    },
    {
      "name": "after",
      "type": "string",
      "required": false
    },
    {
      "name": "timeoutSeconds",
      "type": "integer",
      "required": false
    }
  ],
  "outputs": [
    {
      "name": "files",
      "type": "array",
      "required": false,
      "enablecoercing": true
    }
  ]
}
