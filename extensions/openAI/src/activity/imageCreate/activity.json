{
  "name": "openai-image-create",
  "version": "1.0.0",
  "type": "flogo:activity",
  "title": "Image Create",
  "author": "TIBCO Software",
  "ref": "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/imageCreate",
  "display": {
    "category": "openAI",
    "visible": true,
    "description": "Generates one or more images from a text prompt using OpenAI's image generation API (GPT image models). Note: streaming and partial images are not supported by this activity.",
    "smallIcon": "icons/openAPISmall.png",
    "largeIcon": "icons/openAPILarge.png"
  },
  "feature": {
    "retry": {
      "enabled": true
    }
  },
  "settings": [
    {
      "name": "endPointURL",
      "type": "string",
      "required": true,
      "display": {
        "name": "API Endpoint URL",
        "description": "Endpoint URL for the OpenAI API, for example https://api.openai.com/v1",
        "appPropertySupport": true
      }
    },
    {
      "name": "apiKey",
      "type": "string",
      "required": true,
      "display": {
        "name": "OpenAI API Key",
        "description": "OpenAI key that is required to authenticate with the OpenAI API",
        "appPropertySupport": true
      }
    },
    {
      "name": "model",
      "type": "string",
      "required": false,
      "allowed": [
        "gpt-image-1",
        "gpt-image-1-mini",
        "gpt-image-1.5",
        "gpt-image-2"
      ],
      "display": {
        "name": "Model",
        "description": "Model to use. Defaults to gpt-image-1. Most other parameters depend on this choice. DALL·E 2 and DALL·E 3 were deprecated by OpenAI on May 12, 2026 and replaced by gpt-image-1 / gpt-image-1-mini.",
        "validation": true
      },
      "value": "gpt-image-1"
    },
    {
      "name": "numberOfImages",
      "type": "integer",
      "required": true,
      "display": {
        "name": "Number of Images",
        "description": "How many images to generate. Allowed range 1-10."
      },
      "value": 1
    },
    {
      "name": "size",
      "type": "string",
      "required": false,
      "allowed": [
        "",
        "1024x1024",
        "1536x1024",
        "1024x1536",
        "auto"
      ],
      "display": {
        "name": "Size",
        "description": "Image dimensions. For 'gpt-image-2' arbitrary WxH (multiples of 16, AR 1:3-3:1, max 3840x2160) is also accepted via the validator.",
        "validation": true
      }
    },
    {
      "name": "quality",
      "type": "string",
      "required": false,
      "allowed": [
        "",
        "auto",
        "low",
        "medium",
        "high"
      ],
      "display": {
        "name": "Quality",
        "description": "low | medium | high | auto."
      }
    },
    {
      "name": "outputFormat",
      "type": "string",
      "required": false,
      "allowed": [
        "",
        "png",
        "jpeg",
        "webp"
      ],
      "display": {
        "name": "Output Format",
        "description": "Image file format."
      }
    },
    {
      "name": "background",
      "type": "string",
      "required": false,
      "allowed": [
        "",
        "transparent",
        "opaque",
        "auto"
      ],
      "display": {
        "name": "Background",
        "description": "'transparent' requires Output Format png or webp."
      }
    },
    {
      "name": "outputCompression",
      "type": "integer",
      "required": false,
      "display": {
        "name": "Output Compression",
        "description": "0-100. Only applies when Output Format is webp or jpeg."
      }
    },
    {
      "name": "moderation",
      "type": "string",
      "required": false,
      "allowed": [
        "",
        "low",
        "auto"
      ],
      "display": {
        "name": "Moderation",
        "description": "Content moderation level."
      }
    },
    {
      "name": "user",
      "type": "string",
      "required": false,
      "display": {
        "name": "End-User Identifier",
        "description": "Unique identifier representing your end-user (helps OpenAI detect abuse)."
      }
    }
  ],
  "inputs": [
    {
      "name": "prompt",
      "type": "string",
      "required": true
    }
  ],
  "outputs": [
    {
      "name": "created",
      "type": "integer"
 
    },
    {
      "name": "background",
      "type": "string"
    },
    {
      "name": "outputFormat",
      "type": "string"
    },
    {
      "name": "quality",
      "type": "string"
    },
    {
      "name": "size",
      "type": "string"
    },
    {
      "name": "data",
      "type": "array",
      "enablecoercing": true,
      "value": "[{\"b64_json\":\"\",\"url\":\"\",\"revised_prompt\":\"\"}]"
    },
    {
      "name": "usage",
      "type": "object"
 
    }
  ]
}