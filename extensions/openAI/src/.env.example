# =============================================================================
# Shared .env.example for ALL openAI activity tests
# -----------------------------------------------------------------------------
# Usage:
#   cp .env.example .env       # in this directory (extensions/openAI/src/)
#   <edit values>
#   make test                  # or:  go test ./activity/...
#
# Resolution order (per test file):
#   1. .env in the activity's own directory (per-package, takes precedence)
#   2. .env walked upward from the activity dir until one is found
#   3. real shell environment variables (these always take precedence over
#      values loaded from any .env file)
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI credentials (required for any integration test)
# -----------------------------------------------------------------------------
# The activities historically use two different variable names for the API
# key. Set BOTH to the same value so every test picks it up.
OPENAI_API_KEY=sk-your-key-here

# Base URL for the OpenAI API (or a compatible gateway / Azure endpoint).
OPENAI_API_ENDPOINT_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# Integration test switch
# -----------------------------------------------------------------------------
# Unit tests always run. Integration tests (which call the real API) only run
# when RUN_INTEGRATION=1.
RUN_INTEGRATION=0

# -----------------------------------------------------------------------------
# Vector store related tests
# -----------------------------------------------------------------------------
# Used by: vectorStoreFileList, fileUpload, vectorSearch
VECTOR_STORE_ID=vs_your_vector_store_id_here

# Used by: vectorStoreDelete  (id of the store the test should delete)
#TEST_VECTOR_STORE_ID=vs_abc123

# Used by: vectorStoreCreate  (name to assign to the newly created store)
#TEST_VECTOR_STORE_NAME=flogo-test-store

# -----------------------------------------------------------------------------
# File tests
# -----------------------------------------------------------------------------
# Used by: fileDelete  (id of the file the test should delete)
#TEST_FILE_ID=file-abc123

# Used by: fileUpload (chunking / purpose overrides for the upload)
#TEST_PURPOSE=assistants
#TEST_CHUNK_OVERLAP_TOKENS=400
#TEST_MAX_CHUNK_SIZE_TOKENS=800

# -----------------------------------------------------------------------------
# Misc test controls
# -----------------------------------------------------------------------------
# Used by: fileDelete, fileUpload, vectorStoreCreate, vectorStoreDelete,
#          vectorStoreList
#TEST_TIMEOUT_SECONDS=30

# Used by: vectorStoreList
#TEST_LIMIT=20
