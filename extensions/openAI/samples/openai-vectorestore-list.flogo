{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/vectorStoreList",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-general/src/app/General/trigger/startuphook",
    "github.com/project-flogo/contrib/function/string"
  ],
  "name": "openaiVectorStore-List",
  "description": "",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#startuphook",
      "name": "tibco-appstartup",
      "description": "This trigger allows you to execute flows before other triggers in the application are started. This is useful in initializing application specific tasks.",
      "settings": {},
      "id": "AppStartupTrigger",
      "handlers": [
        {
          "description": "",
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:List_Vectore_stores"
            }
          },
          "name": "List_Vectore_stores"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:List_Vectore_stores",
      "data": {
        "name": "List Vectore stores",
        "description": "",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "ListVectorStores",
            "type": "label",
            "label": "StartActivity to ListVectorStores"
          },
          {
            "id": 2,
            "from": "ListVectorStores",
            "to": "LogOutputAllStores",
            "type": "label",
            "label": "ListVectorStores to LogOutput"
          },
          {
            "id": 3,
            "from": "LogOutputAllStores",
            "to": "Return",
            "type": "label",
            "label": "LogOutput to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "ListVectorStores",
            "name": "ListVectorStores",
            "description": "This activity lists vector stores from OpenAI",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#vectorStoreList",
              "settings": {
                "endPointURL": "=$property[\"OPENAI_API_ENDPOINT_URL\"]",
                "apiKey": "=$property[\"OPENAI_API_KEY\"]"
              },
              "input": {
                "order": "",
                "after": "",
                "before": ""
              },
              "output": {
                "hasMore": false
              },
              "schemas": {
                "output": {
                  "vectorStores": {
                    "type": "json",
                    "value": "{\"$schema\":\"https://json-schema.org/draft/2020-12/schema\",\"type\":\"array\",\"items\":{\"type\":\"object\",\"required\":[\"created_at\",\"expires_after\",\"expires_at\",\"file_counts\",\"id\",\"last_active_at\",\"metadata\",\"name\",\"object\",\"status\",\"usage_bytes\"],\"properties\":{\"id\":{\"type\":\"string\"},\"created_at\":{\"type\":\"integer\"},\"file_counts\":{\"type\":\"object\",\"required\":[\"cancelled\",\"completed\",\"failed\",\"in_progress\",\"total\"],\"properties\":{\"cancelled\":{\"type\":\"integer\"},\"completed\":{\"type\":\"integer\"},\"failed\":{\"type\":\"integer\"},\"in_progress\":{\"type\":\"integer\"},\"total\":{\"type\":\"integer\"}}},\"last_active_at\":{\"type\":\"integer\"},\"metadata\":{\"type\":\"object\"},\"name\":{\"type\":\"string\"},\"object\":{\"type\":\"string\"},\"status\":{\"type\":\"string\"},\"usage_bytes\":{\"type\":\"integer\"},\"expires_after\":{\"type\":\"object\",\"required\":[\"anchor\",\"days\"],\"properties\":{\"anchor\":{\"type\":\"string\"},\"days\":{\"type\":\"integer\"}}},\"expires_at\":{\"type\":\"integer\"}}}}",
                    "fe_metadata": "{\"$schema\":\"https://json-schema.org/draft/2020-12/schema\",\"type\":\"array\",\"items\":{\"type\":\"object\",\"required\":[\"created_at\",\"expires_after\",\"expires_at\",\"file_counts\",\"id\",\"last_active_at\",\"metadata\",\"name\",\"object\",\"status\",\"usage_bytes\"],\"properties\":{\"id\":{\"type\":\"string\"},\"created_at\":{\"type\":\"integer\"},\"file_counts\":{\"type\":\"object\",\"required\":[\"cancelled\",\"completed\",\"failed\",\"in_progress\",\"total\"],\"properties\":{\"cancelled\":{\"type\":\"integer\"},\"completed\":{\"type\":\"integer\"},\"failed\":{\"type\":\"integer\"},\"in_progress\":{\"type\":\"integer\"},\"total\":{\"type\":\"integer\"}}},\"last_active_at\":{\"type\":\"integer\"},\"metadata\":{\"type\":\"object\"},\"name\":{\"type\":\"string\"},\"object\":{\"type\":\"string\"},\"status\":{\"type\":\"string\"},\"usage_bytes\":{\"type\":\"integer\"},\"expires_after\":{\"type\":\"object\",\"required\":[\"anchor\",\"days\"],\"properties\":{\"anchor\":{\"type\":\"string\"},\"days\":{\"type\":\"integer\"}}},\"expires_at\":{\"type\":\"integer\"}}}}"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "LogOutputAllStores",
            "name": "LogOutputAllStores",
            "description": "Simple Log Message Activity",
            "type": "iterator",
            "settings": {
              "iterate": "=$activity[ListVectorStores].vectorStores",
              "accumulate": false
            },
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat(\"Vector store Name: \",$iteration[value].name, \" Id: \", $iteration[value].id)",
                "logLevel": ""
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Simple Return Activity",
            "activity": {
              "ref": "#actreturn"
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUsInkiOjkzfSwiTGlzdFZlY3RvclN0b3JlcyI6eyJ4IjoxNTcsInkiOjgwfSwiTG9nT3V0cHV0QWxsU3RvcmVzIjp7IngiOjM4MSwieSI6NzZ9LCJSZXR1cm4iOnsieCI6NjM0LCJ5Ijo3NX19",
        "metadata": {
          "input": [],
          "output": [],
          "fe_metadata": {}
        }
      }
    }
  ],
  "properties": [
    {
      "name": "OPENAI_API_ENDPOINT_URL",
      "type": "string",
      "value": "https://api.openai.com/v1"
    },
    {
      "name": "OPENAI_API_KEY",
      "type": "string",
      "value": "REPLACE ME"
    }
  ],
  "connections": {},
  "contrib": "",
  "metadata": {
    "endpoints": [],
    "flogoVersion": "2.26.0"
  }
}