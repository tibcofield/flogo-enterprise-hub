{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/TIBCOSoftware/flogo-enterprise-hub/extensions/openAI/activity/fileList",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/tibco/flogo-general/src/app/General/trigger/startuphook",
    "github.com/project-flogo/contrib/function/coerce"
  ],
  "name": "openaiVectorStore-openAI",
  "description": "",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#startuphook",
      "name": "tibco-appstartup",
      "description": "This trigger allows you to execute flows before other triggers in the application are started. This is useful in initializing application specific tasks.",
      "settings": {},
      "id": "AppStartupTrigger",
      "handlers": [
        {
          "description": "",
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:List_files_in_openAI"
            }
          },
          "name": "List_files_in_openAI"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:List_files_in_openAI",
      "data": {
        "note": {
          "author": {
            "name": "VS code user",
            "userId": "vscode"
          },
          "content": "Prerequesit:\n- openAI vectorstore with one or more files associated to it.",
          "createAt": 1779879034356,
          "lastUpdatedAt": 1779879034356,
          "title": "Flow Note"
        },
        "name": "List files in openAI",
        "description": "",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "FileList",
            "type": "label",
            "label": "StartActivity to FileList"
          },
          {
            "id": 2,
            "from": "FileList",
            "to": "LogMessage",
            "type": "label",
            "label": "FileList to LogMessage"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "FileList",
            "name": "FileList",
            "description": "This activity lists files in OpenAI file storage with support for filtering by purpose and pagination",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#fileList",
              "settings": {
                "endPointURL": "=$property[\"OPENAI_API_ENDPOINT_URL\"]",
                "apiKey": "=$property[\"OPENAI_API_KEY\"]"
              },
              "input": {}
            }
          },
          {
            "id": "LogMessage",
            "name": "LogMessage",
            "description": "Simple Log Message Activity",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=coerce.toString($activity[FileList])",
                "logLevel": ""
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIkZpbGVMaXN0Ijp7IngiOjE4NywieSI6NDB9LCJMb2dNZXNzYWdlIjp7IngiOjQ1NiwieSI6NDR9fQ==",
        "metadata": {
          "input": [],
          "output": [],
          "fe_metadata": {}
        }
      }
    }
  ],
  "properties": [
    {
      "name": "OPENAI_API_ENDPOINT_URL",
      "type": "string",
      "value": "https://api.openai.com/v1"
    },
    {
      "name": "OPENAI_API_KEY",
      "type": "string",
      "value": "REPLACE ME"
    }
  ],
  "connections": {},
  "contrib": "",
  "metadata": {
    "endpoints": [],
    "flogoVersion": "2.26.0"
  }
}