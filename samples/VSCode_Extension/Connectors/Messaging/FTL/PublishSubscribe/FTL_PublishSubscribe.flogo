      "name": "FTL.ftlConnection.FTL_Server_Trust_File",
      "type": "string",
      "value": ""
    }
  ],
  "connections": {
    "515a9483-c2cc-4977-a640-c960a3cb8816": {
      "id": "515a9483-c2cc-4977-a640-c960a3cb8816",
      "name": "ftlConnection",
      "ref": "#ftl",
      "isGlobal": false,
      "settings": {
        "name": "ftlConnection",
        "description": "FTL client configuration",
        "serverUrl": "=$property[\"FTL.ftlConnection.FTL_Server_URL\"]",
        "secondaryServerUrl": "=$property[\"FTL.ftlConnection.FTL_Secondary_Server_URL\"]",
        "applicationInstanceId": "=$property[\"FTL.ftlConnection.FTL_Application_Instance_ID\"]",
        "clientLabel": "=$property[\"FTL.ftlConnection.FTL_Client_Label\"]",
        "authenticationMode": "Basic Authentication With TLS",
        "userName": "=$property[\"FTL.ftlConnection.User_Name\"]",
        "password": "=$property[\"FTL.ftlConnection.Password\"]",
        "useCertVerification": "=$property[\"FTL.ftlConnection.Use_certificate_for_verification\"]",
        "trustFile": "=$property[\"FTL.ftlConnection.FTL_Server_Trust_File\"]",
        "clientCertificate": "",
        "clientPrivateKey": "",
        "clientPrivateKeyPassword": "",
        "oauthTokenURL": "",
        "oauthClientId": "",
        "oauthClientSecret": "",
        "oauthTrustFile": ""
      }
    }
