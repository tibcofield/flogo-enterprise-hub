                "value": "{\"order_id\":{\"type\":\"string\",\"description\":\"The order identifier\"},\"status\":{\"type\":\"string\",\"description\":\"Current order status (e.g. processing, shipped, delivered)\"},\"item_count\":{\"type\":\"integer\",\"description\":\"Number of items in the order\"},\"total_usd\":{\"type\":\"number\",\"description\":\"Order total in USD\"},\"estimated_delivery\":{\"type\":\"string\",\"description\":\"Estimated delivery date in ISO 8601 format\"},\"shipping_carrier\":{\"type\":\"string\",\"description\":\"Shipping carrier name\"},\"tracking_number\":{\"type\":\"string\",\"description\":\"Shipment tracking number\"}}"
              }
