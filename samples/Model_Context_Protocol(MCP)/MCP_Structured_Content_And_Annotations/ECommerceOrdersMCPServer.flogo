                      "data": "INTERNAL ORDER ANALYTICS (last 30 days): Total orders: 4,832 | Revenue: $1,247,650 | Avg order value: $258.21 | Fulfillment rate: 96.3% | Avg ship time: 2.1 days | Return rate: 4.7% | Top category: Electronics (38%) | Repeat customer rate: 62% | Cart abandonment: 23.1% | Customer satisfaction: 4.6/5.0 | Peak order hour: 2pm-4pm EST | Mobile orders: 67%",
                      "audience": [
                        "assistant"
                      ],
                      "priority": 0.3
                    }
                  }
                }
              }
            }
          }
