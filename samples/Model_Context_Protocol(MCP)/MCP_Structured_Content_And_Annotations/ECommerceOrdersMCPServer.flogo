{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-mcp/src/app/MCP/trigger/mcpserver",
    "github.com/project-flogo/contrib/function/array"
  ],
  "name": "ECommerceOrdersMCPServer",
  "description": "Demonstrates structured content (Tool Output Schema + structuredContent) and content annotations (audience/priority) in an e-commerce order management scenario",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#mcpserver",
      "name": "flogo-mcp-mcpsever",
      "description": "E-Commerce Orders MCP server with structured content and annotations",
      "settings": {
        "serverName": "ECommerceOrdersMCPServer",
        "serverVersion": "1.0.0",
        "serverType": "HTTP",
        "serverPort": "=$property[\"FlogoMcpServer.PORT\"]",
        "statelessServer": true,
        "serverEndpointPath": "/mcp",
        "enableTLS": false,
        "serverCertificate": "",
        "serverPrivateKey": "",
        "authType": "None",
        "authToken": ""
      },
      "id": "ECommerceOrdersServer",
      "handlers": [
        {
          "description": "Order status with structured content, text and annotations.",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "get_order_status",
            "handlerDescription": "Look up an order by order ID and return its status, items, total, and estimated delivery date. Returns both a human-readable text summary and structuredContent (typed JSON) for programmatic consumption. audience=[user,assistant] priority=0.9.",
            "toolTitle": "Get Order Status",
            "readOnlyToolHint": true,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": false,
            "scope": ""
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:GetOrderStatusFlow"
            },
            "input": {
              "arguments": "=$.arguments"
            },
            "output": {
              "response": "=$.response",
              "structuredContent": "=$.structuredContent"
            }
          },
          "reply": {
            "outputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"order_id\": {\n      \"type\": \"string\",\n      \"description\": \"The order identifier\"\n    },\n    \"status\": {\n      \"type\": \"string\",\n      \"description\": \"Current order status (e.g. processing, shipped, delivered)\"\n    },\n    \"item_count\": {\n      \"type\": \"integer\",\n      \"description\": \"Number of items in the order\"\n    },\n    \"total_usd\": {\n      \"type\": \"number\",\n      \"description\": \"Order total in USD\"\n    },\n    \"estimated_delivery\": {\n      \"type\": \"string\",\n      \"description\": \"Estimated delivery date in ISO 8601 format\"\n    },\n    \"shipping_carrier\": {\n      \"type\": \"string\",\n      \"description\": \"Shipping carrier name\"\n    },\n    \"tracking_number\": {\n      \"type\": \"string\",\n      \"description\": \"Shipment tracking number\"\n    }\n  },\n  \"required\": [\n    \"order_id\",\n    \"status\",\n    \"item_count\",\n    \"total_usd\"\n  ]\n}"
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"audience\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"string\"\r\n      }\r\n    },\r\n    \"priority\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"audience\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"string\"\r\n      }\r\n    },\r\n    \"priority\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              },
              "structuredContent": {
                "type": "json",
                "value": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"order_id\": {\n      \"type\": \"string\",\n      \"description\": \"The order identifier\"\n    },\n    \"status\": {\n      \"type\": \"string\",\n      \"description\": \"Current order status (e.g. processing, shipped, delivered)\"\n    },\n    \"item_count\": {\n      \"type\": \"integer\",\n      \"description\": \"Number of items in the order\"\n    },\n    \"total_usd\": {\n      \"type\": \"number\",\n      \"description\": \"Order total in USD\"\n    },\n    \"estimated_delivery\": {\n      \"type\": \"string\",\n      \"description\": \"Estimated delivery date in ISO 8601 format\"\n    },\n    \"shipping_carrier\": {\n      \"type\": \"string\",\n      \"description\": \"Shipping carrier name\"\n    },\n    \"tracking_number\": {\n      \"type\": \"string\",\n      \"description\": \"Shipment tracking number\"\n    }\n  },\n  \"required\": [\n    \"order_id\",\n    \"status\",\n    \"item_count\",\n    \"total_usd\"\n  ]\n}",
                "fe_metadata": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"order_id\": {\n      \"type\": \"string\",\n      \"description\": \"The order identifier\"\n    },\n    \"status\": {\n      \"type\": \"string\",\n      \"description\": \"Current order status (e.g. processing, shipped, delivered)\"\n    },\n    \"item_count\": {\n      \"type\": \"integer\",\n      \"description\": \"Number of items in the order\"\n    },\n    \"total_usd\": {\n      \"type\": \"number\",\n      \"description\": \"Order total in USD\"\n    },\n    \"estimated_delivery\": {\n      \"type\": \"string\",\n      \"description\": \"Estimated delivery date in ISO 8601 format\"\n    },\n    \"shipping_carrier\": {\n      \"type\": \"string\",\n      \"description\": \"Shipping carrier name\"\n    },\n    \"tracking_number\": {\n      \"type\": \"string\",\n      \"description\": \"Shipment tracking number\"\n    }\n  },\n  \"required\": [\n    \"order_id\",\n    \"status\",\n    \"item_count\",\n    \"total_usd\"\n  ]\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"order_id\": {\n      \"type\": \"string\",\n      \"description\": \"The order ID to look up (e.g. ORD-2026-78901)\"\n    }\n  },\n  \"required\": [\"order_id\"],\n  \"additionalProperties\": false\n}",
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"order_id\": {\n      \"type\": \"string\",\n      \"description\": \"The order ID to look up (e.g. ORD-2026-78901)\"\n    }\n  },\n  \"required\": [\"order_id\"],\n  \"additionalProperties\": false\n}"
              }
            }
          },
          "name": "GetOrderStatusFlow"
        },
        {
          "description": "Internal order analytics with assistant-only audience annotation.",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "get_order_analytics",
            "handlerDescription": "Returns internal order analytics and metrics for LLM reasoning. This data is for the AI assistant's internal use only and is not shown to the human user. audience=[assistant] (LLM only), priority=0.3 (low importance, background context).",
            "toolTitle": "Get Order Analytics",
            "readOnlyToolHint": true,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": false,
            "scope": ""
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:GetOrderAnalyticsFlow"
            },
            "input": {
              "arguments": "=$.arguments"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "reply": {
            "outputSchema": ""
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"audience\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"string\"\r\n      }\r\n    },\r\n    \"priority\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"audience\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"string\"\r\n      }\r\n    },\r\n    \"priority\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"period\": {\n      \"type\": \"string\",\n      \"description\": \"Analytics period: last_7d, last_30d, last_90d. Default last_30d.\"\n    }\n  },\n  \"additionalProperties\": false\n}",
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"period\": {\n      \"type\": \"string\",\n      \"description\": \"Analytics period: last_7d, last_30d, last_90d. Default last_30d.\"\n    }\n  },\n  \"additionalProperties\": false\n}"
              }
            }
          },
          "name": "GetOrderAnalyticsFlow"
        },
        {
          "description": "Urgent shipping alerts with user-only audience annotation.",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "get_shipping_alerts",
            "handlerDescription": "Returns critical shipping alerts and delivery exceptions that require immediate human attention. This information is shown directly to the human user and is not consumed by the LLM. audience=[user] (human only), priority=1.0 (highest importance, urgent).",
            "toolTitle": "Get Shipping Alerts",
            "readOnlyToolHint": true,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": false,
            "scope": ""
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:GetShippingAlertsFlow"
            },
            "input": {
              "arguments": "=$.arguments"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "reply": {
            "outputSchema": ""
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"audience\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"string\"\r\n      }\r\n    },\r\n    \"priority\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"audience\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"string\"\r\n      }\r\n    },\r\n    \"priority\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"severity\": {\n      \"type\": \"string\",\n      \"description\": \"Filter by alert severity: critical, warning, or all. Default all.\"\n    }\n  },\n  \"additionalProperties\": false\n}",
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"severity\": {\n      \"type\": \"string\",\n      \"description\": \"Filter by alert severity: critical, warning, or all. Default all.\"\n    }\n  },\n  \"additionalProperties\": false\n}"
              }
            }
          },
          "name": "GetShippingAlertsFlow"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:GetOrderStatusFlow",
      "data": {
        "name": "GetOrderStatusFlow",
        "description": "Order status with structured content, text and annotations.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "Return",
            "type": "label",
            "label": "StartActivity to Return"
          }
