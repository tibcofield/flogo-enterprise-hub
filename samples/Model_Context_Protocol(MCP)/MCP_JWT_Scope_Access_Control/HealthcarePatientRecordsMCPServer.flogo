      ]
    }
  ],
  "resources": [
    {
      "id": "flow:GetPatientSummaryFlow",
      "data": {
        "name": "GetPatientSummaryFlow",
        "description": "Retrieve patient demographics",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "LogMessage",
            "type": "label",
            "label": "StartActivity to LogMessage"
          },
          {
            "id": 2,
            "from": "LogMessage",
            "to": "Return",
            "type": "label",
            "label": "LogMessage to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "LogMessage",
            "name": "LogMessage",
            "description": "Simple Log Message Activity",
            "activity": {
              "ref": "#log",
              "input": {
                "Log Level": "INFO",
                "flowInfo": false,
                "message": "=string.concat(\"[GetPatientSummary] Caller: \", coerce.toString($flow.tokenInfo.sub), \" | Email: \", coerce.toString($flow.tokenInfo.email), \" | Args: \", coerce.toString($flow.arguments))",
                "logLevel": ""
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Simple Return Activity",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "response": {
                    "mapping": {
                      "data": "{\"patient_id\":\"PAT-10042\",\"first_name\":\"Sarah\",\"last_name\":\"Chen\",\"date_of_birth\":\"1985-03-15\",\"gender\":\"Female\",\"phone\":\"+1-555-0142\",\"email\":\"sarah.chen@email.com\",\"address\":\"742 Elm Street, Springfield, IL 62704\",\"insurance_provider\":\"BlueCross BlueShield\",\"insurance_id\":\"BCB-9920-4401\"}"
                    }
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjEwMCwieSI6MTAwfSwiTG9nTWVzc2FnZSI6eyJ4IjoyNTAsInkiOjEwMH0sIlJldHVybiI6eyJ4Ijo0NTAsInkiOjEwMH19",
        "metadata": {
          "input": [
            {
              "name": "arguments",
              "type": "object",
