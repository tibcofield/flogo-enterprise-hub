{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-mcp/src/app/MCP/trigger/mcpserver",
    "github.com/project-flogo/contrib/function/coerce",
    "github.com/project-flogo/contrib/function/string"
  ],
  "name": "HealthcarePatientRecordsMCPServer",
  "description": "Demonstrates JWT scope-based access control and enhanced tokenInfo claims (iss, sub, aud, name, email) in a healthcare patient records scenario",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#mcpserver",
      "name": "flogo-mcp-mcpsever",
      "description": "Healthcare Patient Records MCP server with JWT scope-based access control",
      "settings": {
        "serverName": "HealthcarePatientRecordsMCPServer",
        "serverVersion": "1.0.0",
        "serverType": "HTTP",
        "serverPort": "=$property[\"FlogoMcpServer.PORT\"]",
        "statelessServer": false,
        "serverEndpointPath": "/mcp",
        "enableTLS": false,
        "serverCertificate": "",
        "serverPrivateKey": "",
        "authType": "JWT Token",
        "authToken": "=$property[\"FlogoMcpServer.JWT_TOKEN_SECRET\"]"
      },
      "id": "HealthcarePatientRecordsServer",
      "handlers": [
        {
          "description": "Retrieve patient demographics",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "get_patient_summary",
            "handlerDescription": "Retrieve patient demographics including name, date of birth, gender, and contact information. Requires the patient:read scope in the JWT token.",
            "toolTitle": "Get Patient Summary",
            "readOnlyToolHint": true,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": false,
            "scope": "patient:read"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:GetPatientSummaryFlow"
            },
            "input": {
              "arguments": "=$.arguments",
              "httpHeaders": "=$.httpHeaders",
              "tokenInfo": "=$.tokenInfo"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "reply": {
            "outputSchema": ""
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"audience\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"string\"\r\n      }\r\n    },\r\n    \"priority\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"audience\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"string\"\r\n      }\r\n    },\r\n    \"priority\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"patient_id\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"The patient ID to look up (e.g. PAT-10042)\"\r\n    }\r\n  },\r\n  \"required\": [\"patient_id\"]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"patient_id\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"The patient ID to look up (e.g. PAT-10042)\"\r\n    }\r\n  },\r\n  \"required\": [\"patient_id\"]\r\n}"
              },
              "httpHeaders": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"Authorization\":{\"type\":\"string\"}}}",
                "fe_metadata": "{\"Authorization\":\"Bearer token\"}"
              },
              "tokenInfo": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"scopes\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n      }\r\n    },\r\n    \"expiration\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"iss\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"sub\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"aud\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n        }\r\n    },\r\n    \"name\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"email\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"scopes\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n      }\r\n    },\r\n    \"expiration\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"iss\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"sub\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"aud\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n        }\r\n    },\r\n    \"name\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"email\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              }
            }
          },
          "name": "GetPatientSummaryFlow"
        },
        {
          "description": "Retrieve sensitive medical history with audit logging",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "get_medical_records",
            "handlerDescription": "Retrieve sensitive medical history including diagnoses, medications, and allergies for a patient. Requires the records:read scope. Access is audit-logged with the caller's subject (sub) and email from the JWT token.",
            "toolTitle": "Get Medical Records",
            "readOnlyToolHint": true,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": false,
            "scope": "records:read"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:GetMedicalRecordsFlow"
            },
            "input": {
              "arguments": "=$.arguments",
              "httpHeaders": "=$.httpHeaders",
              "tokenInfo": "=$.tokenInfo"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "reply": {
            "outputSchema": ""
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"audience\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"string\"\r\n      }\r\n    },\r\n    \"priority\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"audience\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"string\"\r\n      }\r\n    },\r\n    \"priority\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"patient_id\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"The patient ID to look up (e.g. PAT-10042)\"\r\n    },\r\n    \"record_type\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"Filter by record type: diagnoses, medications, allergies, or all. Default all.\"\r\n    }\r\n  },\r\n  \"required\": [\"patient_id\"]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"patient_id\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"The patient ID to look up (e.g. PAT-10042)\"\r\n    },\r\n    \"record_type\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"Filter by record type: diagnoses, medications, allergies, or all. Default all.\"\r\n    }\r\n  },\r\n  \"required\": [\"patient_id\"]\r\n}"
              },
              "httpHeaders": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"Authorization\":{\"type\":\"string\"}}}",
                "fe_metadata": "{\"Authorization\":\"Bearer token\"}"
              },
              "tokenInfo": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"scopes\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n      }\r\n    },\r\n    \"expiration\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"iss\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"sub\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"aud\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n        }\r\n    },\r\n    \"name\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"email\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"scopes\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n      }\r\n    },\r\n    \"expiration\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"iss\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"sub\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"aud\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n        }\r\n    },\r\n    \"name\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"email\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              }
            }
          },
          "name": "GetMedicalRecordsFlow"
        },
        {
          "description": "Update patient contact information with audit trail",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "update_patient_contact",
            "handlerDescription": "Update patient contact information (phone number, email, address). Requires the patient:write scope. The update is attributed to the caller via tokenInfo.sub (subject) for audit trail.",
            "toolTitle": "Update Patient Contact",
            "readOnlyToolHint": false,
            "destructiveToolHint": false,
            "idempotentToolHint": true,
            "openWorldToolHint": false,
            "scope": "patient:write"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:UpdatePatientContactFlow"
            },
            "input": {
              "arguments": "=$.arguments",
              "httpHeaders": "=$.httpHeaders",
              "tokenInfo": "=$.tokenInfo"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "reply": {
            "outputSchema": ""
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"audience\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"string\"\r\n      }\r\n    },\r\n    \"priority\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"audience\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"string\"\r\n      }\r\n    },\r\n    \"priority\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"patient_id\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"The patient ID to update (e.g. PAT-10042)\"\r\n    },\r\n    \"phone\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"New phone number (e.g. +1-555-0199)\"\r\n    },\r\n    \"email\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"New email address\"\r\n    },\r\n    \"address\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"New mailing address\"\r\n    }\r\n  },\r\n  \"required\": [\"patient_id\"]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"patient_id\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"The patient ID to update (e.g. PAT-10042)\"\r\n    },\r\n    \"phone\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"New phone number (e.g. +1-555-0199)\"\r\n    },\r\n    \"email\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"New email address\"\r\n    },\r\n    \"address\": {\r\n      \"type\": \"string\",\r\n      \"description\": \"New mailing address\"\r\n    }\r\n  },\r\n  \"required\": [\"patient_id\"]\r\n}"
              },
              "httpHeaders": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"Authorization\":{\"type\":\"string\"}}}",
                "fe_metadata": "{\"Authorization\":\"Bearer token\"}"
              },
              "tokenInfo": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"scopes\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n      }\r\n    },\r\n    \"expiration\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"iss\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"sub\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"aud\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n        }\r\n    },\r\n    \"name\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"email\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"scopes\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n      }\r\n    },\r\n    \"expiration\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"iss\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"sub\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"aud\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n        }\r\n    },\r\n    \"name\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"email\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              }
            }
          },
          "name": "UpdatePatientContactFlow"
        },
        {
          "description": "Return decoded JWT token claims",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "get_token_info",
            "handlerDescription": "Returns the decoded JWT token information including scopes, expiration, issuer (iss), subject (sub), audience (aud), name, and email. Use this tool to inspect what claims and scopes your token carries. Requires the token:inspect scope.",
            "toolTitle": "Get Token Info",
            "readOnlyToolHint": true,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": false,
            "scope": "token:inspect"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:GetTokenInfoFlow"
            },
            "input": {
              "arguments": "=$.arguments",
              "httpHeaders": "=$.httpHeaders",
              "tokenInfo": "=$.tokenInfo"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "reply": {
            "outputSchema": ""
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"audience\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"string\"\r\n      }\r\n    },\r\n    \"priority\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"audience\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n        \"type\": \"string\"\r\n      }\r\n    },\r\n    \"priority\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {}\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {}\r\n}"
              },
              "httpHeaders": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"Authorization\":{\"type\":\"string\"}}}",
                "fe_metadata": "{\"Authorization\":\"Bearer token\"}"
              },
              "tokenInfo": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"scopes\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n      }\r\n    },\r\n    \"expiration\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"iss\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"sub\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"aud\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n        }\r\n    },\r\n    \"name\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"email\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"scopes\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n      }\r\n    },\r\n    \"expiration\": {\r\n      \"type\": \"number\"\r\n    },\r\n    \"iss\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"sub\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"aud\": {\r\n      \"type\": \"array\",\r\n      \"items\": {\r\n          \"type\": \"string\"\r\n        }\r\n    },\r\n    \"name\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"email\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
