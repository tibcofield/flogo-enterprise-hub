                    "mapping": {
                      "data": "{\"patient_id\":\"PAT-10042\",\"diagnoses\":[{\"code\":\"E11.9\",\"description\":\"Type 2 diabetes mellitus without complications\",\"diagnosed_date\":\"2019-06-20\",\"status\":\"active\"},{\"code\":\"I10\",\"description\":\"Essential hypertension\",\"diagnosed_date\":\"2020-01-15\",\"status\":\"active\"}],\"medications\":[{\"name\":\"Metformin\",\"dosage\":\"500mg\",\"frequency\":\"twice daily\",\"prescribed_date\":\"2019-06-20\"},{\"name\":\"Lisinopril\",\"dosage\":\"10mg\",\"frequency\":\"once daily\",\"prescribed_date\":\"2020-01-15\"}],\"allergies\":[{\"allergen\":\"Penicillin\",\"reaction\":\"Hives\",\"severity\":\"moderate\"}]}"
                    }
                  }
                }
              }
            }
          }
