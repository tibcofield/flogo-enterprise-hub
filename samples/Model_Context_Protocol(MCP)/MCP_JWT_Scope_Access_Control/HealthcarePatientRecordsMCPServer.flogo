      "data": {
        "name": "GetMedicalRecordsFlow",
        "description": "Retrieve sensitive medical history with audit logging",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "LogMessage",
            "type": "label",
            "label": "StartActivity to LogMessage"
          },
