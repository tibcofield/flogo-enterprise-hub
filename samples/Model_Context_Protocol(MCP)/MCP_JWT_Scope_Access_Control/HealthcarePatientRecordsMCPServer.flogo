                "message": "=string.concat(\"[AUDIT] Medical records accessed by sub=\", coerce.toString($flow.tokenInfo.sub), \" email=\", coerce.toString($flow.tokenInfo.email), \" iss=\", coerce.toString($flow.tokenInfo.iss), \" for patient=\", coerce.toString($flow.arguments.patient_id))",
