                      "data": "{\"destination\":\"Paris, France\",\"startDate\":\"2026-07-13\",\"durationDays\":5,\"forecast\":[{\"date\":\"2026-07-13\",\"condition\":\"Sunny\",\"highC\":29,\"lowC\":19,\"precipMm\":0,\"uvIndex\":7,\"windKmh\":10},{\"date\":\"2026-07-14\",\"condition\":\"Mostly Sunny\",\"highC\":31,\"lowC\":20,\"precipMm\":0,\"uvIndex\":8,\"windKmh\":8},{\"date\":\"2026-07-15\",\"condition\":\"Partly Cloudy\",\"highC\":28,\"lowC\":19,\"precipMm\":1,\"uvIndex\":6,\"windKmh\":12},{\"date\":\"2026-07-16\",\"condition\":\"Scattered Showers\",\"highC\":25,\"lowC\":18,\"precipMm\":6,\"uvIndex\":4,\"windKmh\":16},{\"date\":\"2026-07-17\",\"condition\":\"Sunny\",\"highC\":30,\"lowC\":20,\"precipMm\":0,\"uvIndex\":7,\"windKmh\":9}],\"summary\":\"Warm mid-July weather typical for Paris. Expect highs around 28-31C with one rainy day on July 16 — bring a compact umbrella for that afternoon. UV is high; sunscreen essential for outdoor conference activities.\",\"packingTips\":[\"Light summer clothes\",\"Compact umbrella or rain jacket\",\"Sunscreen SPF 30+\",\"Comfortable walking shoes\",\"Refillable water bottle — stay hydrated\"]}",
