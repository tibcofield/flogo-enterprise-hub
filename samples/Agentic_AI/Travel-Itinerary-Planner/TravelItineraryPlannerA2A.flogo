{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/trigger/agent",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/connector/llmprovider"
  ],
  "name": "TravelItineraryPlannerA2A",
  "description": "A2A Server agent for planning travel itineraries - searches flights, hotels, and weather forecasts.",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#agent",
      "name": "flogo-agenticai-agent",
      "description": "Travel Itinerary Planner A2A Server agent on port 9898.",
      "settings": {
        "llmProviderConnection": "conn://fa11aaaa-bbbb-cccc-dddd-eeee00000001",
        "agentName": "=$property[\"Trigger_Settings.AgentName\"]",
        "agentDescription": "=$property[\"Trigger_Settings.AgentDescription\"]",
        "agentType": "A2A Server",
        "agentPort": "=$property[\"A2A.port\"]",
        "agentUrl": "=$property[\"A2A.AgentUrl\"]",
        "agentAuthMode": "=$property[\"A2A.AuthMode\"]",
        "agentToken": "=$property[\"A2A.AuthToken\"]",
        "model": "=$property[\"Trigger_Settings.LLM_Model\"]",
        "reasoning": "",
        "temperature": "=$property[\"Trigger_Settings.LLM_temperature\"]",
        "enableGuardrails": true,
        "rateLimit": "=$property[\"Trigger_Settings.Rate_Limit\"]",
        "tokenLimit": "=$property[\"Trigger_Settings.Token_Limit\"]",
        "redactSensitiveData": "=$property[\"Trigger_Settings.Redact_Sensitive_Data\"]",
        "remoteAgents": [],
        "mcpServers": [],
        "conversationStoreType": "Memory",
        "memoryMaxSize": 20,
        "systemPrompt": "You are a specialized travel itinerary planning assistant exposed as an A2A-compatible agent.\n\nYou are called by orchestrator agents, travel applications, and virtual assistants that need expert travel planning capabilities. Your role is to help plan complete, enjoyable, and realistic trips.\n\n## Your Tools\n\n- **SearchFlights**: Search for available flights between airports by date, passenger count, and cabin class. Always use IATA codes for airports. If the user specifies city names, infer the most likely IATA code (e.g. Paris → CDG).\n- **SearchHotels**: Find available hotels in a destination city for the requested dates, guest count, and star-rating preference.\n- **GetWeatherForecast**: Retrieve a multi-day weather forecast for the destination so travelers can pack and plan activities appropriately.\n- **BuildItinerary**: Once the user has selected a flight and hotel, compile the complete trip plan, assign an itinerary ID, and confirm all details.\n\n## Behavior Guidelines\n\n- Always confirm required parameters before calling a tool (origin, destination, travel dates, passenger count)\n- Present flight and hotel results in clear markdown tables with key fields (airline, price, duration, stops; hotel name, stars, price/night)\n- After searching flights or hotels, proactively offer the weather forecast for the destination\n- Before calling BuildItinerary, summarize the chosen flights and hotel and ask for explicit confirmation\n- All prices are in USD unless the user requests otherwise\n- If a search returns no results, suggest alternatives (nearby airports, ±3 day date shifts, relaxed star-rating)\n- Keep responses concise — the caller is typically another agent, not a human reading a long narrative"
      },
      "id": "TravelPlannerA2AServer",
      "handlers": [
        {
          "description": "Searches for available flights and returns matching options.",
          "settings": {
            "handlerType": "Tool",
            "agentToolName": "SearchFlights",
            "agentToolDescription": "Search for available flights between two airports for a given departure date, number of passengers, and cabin class preference. Returns a list of matching flight options with airline, flight number, departure/arrival times, duration, stops, cabin class, price in USD, and available seats.",
            "agentSkillTags": "SearchFlights,flights,travel,booking,air_travel",
            "agentSkillExamples": "Find me direct flights from JFK to CDG next Tuesday.|Search economy class flights from London to Tokyo for 2 passengers on July 13th.|What flights are available from SFO to LHR next month?|Look up business class options from NYC to Paris departing July 13.|Show available round-trip flights from Chicago to Amsterdam departing July 13 returning July 17.",
            "customGuardrailType": "BOTH",
            "customConversationStoreOperation": "STORE"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:search_flights_flow"
            },
            "input": {
              "toolParams": "=$.toolParams"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              },
              "customConversationStoreOpOutput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}"
              }
            },
            "output": {
              "toolParams": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"origin\":{\"type\":\"string\"},\"destination\":{\"type\":\"string\"},\"departureDate\":{\"type\":\"string\"},\"returnDate\":{\"type\":\"string\"},\"passengers\":{\"type\":\"number\"},\"cabinClass\":{\"type\":\"string\"}}}",
                "fe_metadata": "{\"origin\":\"JFK\",\"destination\":\"CDG\",\"departureDate\":\"2026-07-13\",\"returnDate\":\"2026-07-17\",\"passengers\":1,\"cabinClass\":\"economy\"}"
              },
              "customGuardrailInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}"
              },
              "customConversationStoreOpInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}"
              }
            }
          },
          "name": "search_flights_flow"
        },
        {
          "description": "Searches for available hotels in a destination city.",
          "settings": {
            "handlerType": "Tool",
            "agentToolName": "SearchHotels",
            "agentToolDescription": "Search for available hotels in a destination city for the requested check-in and check-out dates, number of guests, and optional minimum star-rating preference. Returns a list of matching hotels with name, star rating, distance from city centre, room type, price per night, total price, and amenities.",
            "agentSkillTags": "SearchHotels,hotels,accommodation,lodging,travel",
            "agentSkillExamples": "Find 4-star hotels in Paris for July 13-17 for 2 guests.|Search luxury hotels in Tokyo near the city centre.|What hotels are available in Barcelona for next weekend?|Look up 3-star or better accommodation in Rome for a family of 4.|Find budget hotels in London between July 10 and July 17 for 1 guest.",
            "customGuardrailType": "BOTH",
            "customConversationStoreOperation": "STORE"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:search_hotels_flow"
            },
            "input": {
              "toolParams": "=$.toolParams"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              },
              "customConversationStoreOpOutput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}"
              }
            },
            "output": {
              "toolParams": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"city\":{\"type\":\"string\"},\"checkInDate\":{\"type\":\"string\"},\"checkOutDate\":{\"type\":\"string\"},\"guests\":{\"type\":\"number\"},\"minStarRating\":{\"type\":\"number\"}}}",
                "fe_metadata": "{\"city\":\"Paris\",\"checkInDate\":\"2026-07-13\",\"checkOutDate\":\"2026-07-17\",\"guests\":2,\"minStarRating\":3}"
              },
              "customGuardrailInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}"
              },
              "customConversationStoreOpInput": {
