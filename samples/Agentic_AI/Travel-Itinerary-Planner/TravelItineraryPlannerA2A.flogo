                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}"
              }
            }
          },
          "name": "get_weather_flow"
        },
        {
          "description": "Builds and confirms the final travel itinerary.",
          "settings": {
            "handlerType": "Tool",
            "agentToolName": "BuildItinerary",
            "agentToolDescription": "Compile the final travel itinerary from the user's selected flights and hotel. Generates a unique itinerary reference ID, calculates the total estimated cost, and returns a complete trip plan the caller can display to the end user. Always call this only after the user explicitly confirms their selections.",
            "agentSkillTags": "BuildItinerary,itinerary,trip,booking,confirmation,travel_plan",
            "agentSkillExamples": "Build a complete itinerary for my Paris trip from July 13 to July 17.|Create a travel plan for Jane Doe's European vacation with flight FL-001 and hotel HTL-003.|Confirm my trip with the nonstop United flight and the 4-star Boutique Marais hotel.|Finalize and summarize the travel plan I've selected.|Save my travel plan and give me a reference number.",
            "customGuardrailType": "BOTH",
            "customConversationStoreOperation": "STORE"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:build_itinerary_flow"
            },
            "input": {
              "toolParams": "=$.toolParams"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              },
              "customConversationStoreOpOutput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}"
              }
            },
            "output": {
              "toolParams": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"tripName\":{\"type\":\"string\"},\"travelerName\":{\"type\":\"string\"},\"startDate\":{\"type\":\"string\"},\"endDate\":{\"type\":\"string\"},\"selectedFlightIds\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"selectedHotelId\":{\"type\":\"string\"},\"notes\":{\"type\":\"string\"}}}",
