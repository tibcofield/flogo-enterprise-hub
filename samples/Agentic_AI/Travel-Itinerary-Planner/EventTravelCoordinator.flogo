          },
          "name": "register_attendee_travel_flow"
        }
      ]
    },
    {
      "ref": "#rest",
      "name": "tibco-wi-rest",
      "description": "REST endpoint for event travel coordination requests.",
      "settings": {
        "port": 9091,
        "APISpecUpdate": false,
        "swagger": "",
        "swaggerVersion": "v2",
        "authenticationType": "None",
        "username": "",
        "password": "",
        "apiVersion": "1.0.0",
        "secureConnection": false,
        "serverKey": "",
        "caCertificate": ""
      },
      "id": "ReceiveHTTPMessage",
      "handlers": [
        {
          "description": "Receives event travel requests via REST and invokes the EventTravelAgent.",
          "settings": {
            "Method": "POST",
            "reqType": "application/json",
            "Path": "/event-travel/{eventId}",
            "OutputValidation": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:event_travel_flow"
            },
            "input": {
              "pathParams": "=$.pathParams",
              "headers": "=$.headers",
              "body": {
                "mapping": {
                  "request": "=$.body.request"
                }
              }
            },
            "output": {
              "code": "=$.code",
              "data": "=$.data"
            }
          },
          "reply": {
            "code": 200,
            "configureResponseCodes": false,
            "message": {}
          },
          "schemas": {
            "reply": {
              "data": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"response\":{\"type\":\"string\"}}}",
                "fe_metadata": "{\"response\":\"agent reply\"}"
              },
              "responseBody": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"body\":{\"type\":\"any\"},\"headers\":{\"type\":\"object\"}}}"
              }
            },
            "output": {
              "pathParams": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"eventId\":{\"type\":\"string\"}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"eventId\",\"type\":\"string\"}]"
              },
              "headers": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
              },
              "body": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"request\":{\"type\":\"string\"}}}",
                "fe_metadata": "{\"request\":\"I need to book travel for a speaker attending the European Tech Summit.\"}"
              }
            }
          },
          "name": "event_travel_flow"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:event_travel_flow",
      "data": {
        "name": "event_travel_flow",
        "description": "Receives event travel requests via REST and invokes the EventTravelAgent.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "InvokeEventTravelAgent",
            "type": "label",
            "label": "StartActivity to InvokeEventTravelAgent"
          },
          {
            "id": 2,
            "from": "InvokeEventTravelAgent",
            "to": "Return",
            "type": "label",
            "label": "InvokeEventTravelAgent to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "InvokeEventTravelAgent",
            "name": "InvokeEventTravelAgent",
            "description": "Invokes the EventTravelAgent with the travel coordination request.",
            "activity": {
              "ref": "#callagent",
              "input": {
                "agentName": "EventTravelAgent",
                "prompt": "=$flow.body.request",
                "structuredOutput": false,
                "conversationId": "=$flow.pathParams.eventId"
              }
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Returns the agent response to the caller.",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "code": 200,
                  "data": {
                    "mapping": {
                      "response": "=$activity[InvokeEventTravelAgent].response"
                    }
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjEwMCwieSI6MTAwfSwiSW52b2tlRXZlbnRUcmF2ZWxBZ2VudCI6eyJ4IjozMDAsInkiOjEwMH0sIlJldHVybiI6eyJ4Ijo1MDAsInkiOjEwMH19",
        "metadata": {
          "input": [
            {
              "name": "pathParams",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"eventId\":{\"type\":\"string\"}}"
