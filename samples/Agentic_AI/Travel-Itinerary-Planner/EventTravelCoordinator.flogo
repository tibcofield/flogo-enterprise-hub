{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/activity/callagent",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/trigger/agent",
    "github.com/tibco/flogo-general/src/app/General/trigger/rest",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/connector/llmprovider",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/connector/a2aserverconnection"
  ],
  "name": "EventTravelCoordinator",
  "description": "Conference and event travel coordinator that manages attendee travel logistics, delegating flight and hotel searches to a remote TravelPlanner A2A Server agent.",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#agent",
      "name": "flogo-agenticai-agent",
      "description": "Event travel agent with venue details and attendee registration tools.",
      "settings": {
        "llmProviderConnection": "conn://ca33aaaa-1111-2222-3333-444455550003",
        "agentName": "=$property[\"Trigger_Settings.AgentName\"]",
        "agentDescription": "=$property[\"Trigger_Settings.AgentDescription\"]",
        "agentType": "Local",
        "agentPort": "8091",
        "agentUrl": "http://localhost:9898",
        "agentAuthMode": "None",
        "agentToken": "",
        "model": "=$property[\"Trigger_Settings.LLM_Model\"]",
        "reasoning": "",
        "temperature": "=$property[\"Trigger_Settings.LLM_temperature\"]",
        "enableGuardrails": true,
        "rateLimit": "=$property[\"Trigger_Settings.Rate_Limit\"]",
        "tokenLimit": "=$property[\"Trigger_Settings.Token_Limit\"]",
        "redactSensitiveData": "=$property[\"Trigger_Settings.Redact_Sensitive_Data\"]",
        "remoteAgents": [
          "conn://ca33bbbb-1111-2222-3333-444455550003"
        ],
        "mcpServers": [],
        "conversationStoreType": "Memory",
        "memoryMaxSize": 20,
        "systemPrompt": "You are a travel coordinator for Summit Events, a leading conference and event management company.\n\n## Your Role\nYou coordinate travel logistics for conference attendees, speakers, and staff. You have access to a remote Travel Planner agent that searches flights, hotels, checks weather, and builds itineraries. You also have local tools for event details and attendee registration.\n\n## Workflow\n1. When a request comes in, ALWAYS call GetEventDetails first to retrieve the conference venue, dates, nearest airports, and partner hotels\n2. Use the event's nearest airports and dates to guide flight searches via the remote Travel Planner agent\n3. Prioritize partner hotels when recommending accommodation — they offer event-negotiated rates\n4. After the attendee selects flights and hotel, call RegisterAttendeeTravel to log their confirmed travel plan\n5. Proactively offer weather forecasts for the event dates and suggest what to pack\n\n## Key Guidelines\n- Always mention the event name and dates in your responses for context\n- Recommend arriving the day before the event starts and departing the day after it ends\n- For speakers and VIPs, suggest premium options; for general attendees, suggest budget-friendly options\n- Group rate partner hotels should be presented first, with the event discount highlighted\n- Include ground transportation tips (shuttle service, taxi, public transit from airport to venue)\n\n## Response Style\n- Organized and efficient — event travelers need clear, actionable information\n- Use tables or bullet lists for comparing options\n- Include the registration confirmation ID at the end of every completed booking\n- Mention the event's networking events or pre-conference workshops if relevant"
      },
      "id": "EventTravelAgentTrigger",
      "handlers": [
        {
          "description": "Retrieves conference event details including venue, dates, airports, and partner hotels.",
          "settings": {
            "handlerType": "Tool",
            "agentToolName": "GetEventDetails",
            "agentToolDescription": "Retrieves full details for a Summit Events conference including venue name and address, event dates, pre-conference workshop dates, nearest airports with IATA codes and transit times, partner hotels with event-negotiated rates and promo codes, shuttle service schedule, and current registration count. Always call this first to provide event-aware travel recommendations.",
            "agentSkillTags": "GetEventDetails,event,conference,venue,schedule,logistics",
            "agentSkillExamples": "Get details for the European Tech Summit 2026.|What are the nearest airports to the SUMMIT-2026-EU venue?|Show me partner hotels for the upcoming summit.|When does the European Tech Summit start and what's the venue address?",
            "customGuardrailType": "BOTH",
            "customConversationStoreOperation": "STORE"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:get_event_details_flow"
            },
            "input": {
              "toolParams": "=$.toolParams"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              },
              "customConversationStoreOpOutput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}"
              }
            },
            "output": {
              "toolParams": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"eventId\":{\"type\":\"string\"},\"eventName\":{\"type\":\"string\"}}}",
                "fe_metadata": "{\"eventId\":\"SUMMIT-2026-EU\",\"eventName\":\"European Tech Summit 2026\"}"
              },
              "customGuardrailInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}"
              },
              "customConversationStoreOpInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}"
              }
            }
          },
          "name": "get_event_details_flow"
        },
        {
          "description": "Registers confirmed travel plan for a conference attendee.",
          "settings": {
            "handlerType": "Tool",
            "agentToolName": "RegisterAttendeeTravel",
            "agentToolDescription": "Logs a confirmed travel plan for a conference attendee. Records their flight and hotel selections, arrival and departure dates, attendee role (Speaker/VIP/General), and automatically books the complimentary airport shuttle if available. Returns a registration confirmation ID, badge type, and next steps. Only call this after the attendee has confirmed their flight and hotel choices.",
            "agentSkillTags": "RegisterAttendeeTravel,registration,attendee,booking,confirmation,event",
            "agentSkillExamples": "Register Alex Rivera (Speaker) for the European Tech Summit with UA 456 and Hyatt Regency.|Confirm travel for a general attendee arriving Jul 13 at the Ibis hotel.|Log the speaker's confirmed travel plan for SUMMIT-2026-EU.|Register an attendee who booked Air France to CDG and the Concorde Montparnasse hotel.",
            "customGuardrailType": "BOTH",
            "customConversationStoreOperation": "STORE"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:register_attendee_travel_flow"
            },
            "input": {
              "toolParams": "=$.toolParams"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              },
              "customConversationStoreOpOutput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}"
              }
            },
            "output": {
              "toolParams": {
                "type": "json",
                "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"eventId\":{\"type\":\"string\"},\"attendeeName\":{\"type\":\"string\"},\"attendeeEmail\":{\"type\":\"string\"},\"attendeeRole\":{\"type\":\"string\"},\"flightDetails\":{\"type\":\"string\"},\"hotelDetails\":{\"type\":\"string\"},\"arrivalDate\":{\"type\":\"string\"},\"departureDate\":{\"type\":\"string\"}}}",
                "fe_metadata": "{\"eventId\":\"SUMMIT-2026-EU\",\"attendeeName\":\"Alex Rivera\",\"attendeeEmail\":\"alex.r@techcorp.com\",\"attendeeRole\":\"Speaker\",\"flightDetails\":\"UA 456 JFK-CDG Jul 13\",\"hotelDetails\":\"Hyatt Regency Paris Etoile 4 nights\",\"arrivalDate\":\"2026-07-13\",\"departureDate\":\"2026-07-17\"}"
              },
              "customGuardrailInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}"
              },
              "customConversationStoreOpInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}"
