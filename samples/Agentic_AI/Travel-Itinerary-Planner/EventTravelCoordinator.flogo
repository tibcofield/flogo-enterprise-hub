          "fe_metadata": {
            "input": "{\"type\": \"object\", \"title\": \"ReceiveHTTPMessage\", \"properties\": {\"pathParams\": {\"type\": \"object\", \"properties\": {\"eventId\": {\"type\": \"string\"}}, \"required\": []}, \"headers\": {\"type\": \"object\", \"properties\": {\"Accept\": {\"type\": \"string\", \"visible\": false}, \"Accept-Charset\": {\"type\": \"string\", \"visible\": false}, \"Accept-Encoding\": {\"type\": \"string\", \"visible\": false}, \"Authorization\": {\"type\": \"string\", \"visible\": false}, \"Connection\": {\"type\": \"string\", \"visible\": false}, \"Content-Length\": {\"type\": \"string\", \"visible\": false}, \"Content-Type\": {\"type\": \"string\", \"visible\": false}, \"Cookie\": {\"type\": \"string\", \"visible\": false}, \"Pragma\": {\"type\": \"string\", \"visible\": false}}, \"required\": []}, \"body\": {\"$schema\": \"http://json-schema.org/draft-04/schema#\", \"type\": \"object\", \"properties\": {\"request\": {\"type\": \"string\"}}}, \"requestURI\": {\"type\": \"string\", \"required\": false}, \"method\": {\"type\": \"string\", \"required\": false}}}",
            "output": "{\"type\":\"object\",\"title\":\"Inputs\",\"properties\":{\"code\":{\"type\":\"integer\"},\"data\":{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"response\":{\"type\":\"string\"}}}},\"required\":[]}"
