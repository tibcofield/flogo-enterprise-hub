{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-mcp/src/app/MCP/trigger/mcpserver",
    "github.com/project-flogo/contrib/function/coerce",
    "github.com/project-flogo/contrib/function/string"
  ],
  "name": "IdentityAccessMCPServer",
  "description": "MCP server exposing 50 identity and access management tools covering user lifecycle, password management, roles and permissions, group management, MFA, API keys, sessions, and compliance auditing.",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#mcpserver",
      "name": "flogo-mcp-mcpsever",
      "description": "MCP server exposing IdentityAccessMCPServer tools",
      "settings": {
        "serverName": "IdentityAccessMCPServer",
        "serverVersion": "1.0.0",
        "serverType": "HTTP",
        "serverPort": "=$property[\"FlogoMcpServer.PORT\"]",
        "statelessServer": false,
        "serverEndpointPath": "/mcp",
        "enableTLS": false,
        "serverCertificate": "",
        "serverPrivateKey": "",
        "authType": "None",
        "authToken": ""
      },
      "id": "IdentityAccessMCPServer",
      "handlers": [
        {
          "description": "Create a new user account in enterprise systems",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "create_user",
            "handlerDescription": "Create a new user account across enterprise systems including Active Directory, email, and collaboration tools. Provisions the user with default permissions based on department and role. Returns the new user ID and provisioned systems.",
            "readOnlyToolHint": false,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": true
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:create_user"
            },
            "input": {
              "arguments": "=$.arguments"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"employee_id\": {\n      \"type\": \"string\",\n      \"description\": \"New employee ID to assign\"\n    },\n    \"full_name\": {\n      \"type\": \"string\",\n      \"description\": \"Full name of the new employee\"\n    },\n    \"email\": {\n      \"type\": \"string\",\n      \"description\": \"Corporate email address\"\n    },\n    \"department\": {\n      \"type\": \"string\",\n      \"description\": \"Department name, e.g. Engineering, Sales, HR\"\n    },\n    \"role\": {\n      \"type\": \"string\",\n      \"description\": \"Job title or role\"\n    },\n    \"manager_id\": {\n      \"type\": \"string\",\n      \"description\": \"Employee ID of the direct manager\"\n    }\n  },\n  \"required\": [\n    \"employee_id\",\n    \"full_name\",\n    \"email\",\n    \"department\",\n    \"role\"\n  ],\n  \"additionalProperties\": false\n}",
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"employee_id\": {\n      \"type\": \"string\",\n      \"description\": \"New employee ID to assign\"\n    },\n    \"full_name\": {\n      \"type\": \"string\",\n      \"description\": \"Full name of the new employee\"\n    },\n    \"email\": {\n      \"type\": \"string\",\n      \"description\": \"Corporate email address\"\n    },\n    \"department\": {\n      \"type\": \"string\",\n      \"description\": \"Department name, e.g. Engineering, Sales, HR\"\n    },\n    \"role\": {\n      \"type\": \"string\",\n      \"description\": \"Job title or role\"\n    },\n    \"manager_id\": {\n      \"type\": \"string\",\n      \"description\": \"Employee ID of the direct manager\"\n    }\n  },\n  \"required\": [\n    \"employee_id\",\n    \"full_name\",\n    \"email\",\n    \"department\",\n    \"role\"\n  ],\n  \"additionalProperties\": false\n}"
              }
            }
          },
          "name": "create_user"
        },
        {
          "description": "Delete and deprovision a user account from all systems",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "delete_user",
            "handlerDescription": "Delete and deprovision a user account from all enterprise systems. Revokes all access, removes group memberships, and archives user data per retention policy. Requires manager or HR approval confirmation.",
            "readOnlyToolHint": false,
            "destructiveToolHint": true,
            "idempotentToolHint": false,
            "openWorldToolHint": true
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:delete_user"
            },
            "input": {
              "arguments": "=$.arguments"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"employee_id\": {\n      \"type\": \"string\",\n      \"description\": \"Employee ID to deprovision\"\n    },\n    \"reason\": {\n      \"type\": \"string\",\n      \"description\": \"Reason for deletion, e.g. resignation, termination, contract_end\"\n    },\n    \"archive_data\": {\n      \"type\": \"string\",\n      \"description\": \"Whether to archive user data before deletion (true/false)\"\n    }\n  },\n  \"required\": [\n    \"employee_id\",\n    \"reason\"\n  ],\n  \"additionalProperties\": false\n}",
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"employee_id\": {\n      \"type\": \"string\",\n      \"description\": \"Employee ID to deprovision\"\n    },\n    \"reason\": {\n      \"type\": \"string\",\n      \"description\": \"Reason for deletion, e.g. resignation, termination, contract_end\"\n    },\n    \"archive_data\": {\n      \"type\": \"string\",\n      \"description\": \"Whether to archive user data before deletion (true/false)\"\n    }\n  },\n  \"required\": [\n    \"employee_id\",\n    \"reason\"\n  ],\n  \"additionalProperties\": false\n}"
              }
            }
          },
          "name": "delete_user"
        },
        {
