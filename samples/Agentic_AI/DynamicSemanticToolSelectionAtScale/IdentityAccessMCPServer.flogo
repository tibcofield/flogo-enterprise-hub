        {
          "description": "Reset a user's password for a specified service",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "reset_password",
            "handlerDescription": "Reset a user's password for a specified service such as VPN, email, or Active Directory. Generates a temporary password and sends a reset link to the user's registered email. Returns confirmation with the reset method used and expiration time.",
            "readOnlyToolHint": false,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": true
          },
