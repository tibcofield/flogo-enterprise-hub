                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"employee_id\": {\n      \"type\": \"string\",\n      \"description\": \"Employee ID to suspend\"\n    },\n    \"reason\": {\n      \"type\": \"string\",\n      \"description\": \"Reason for suspension\"\n    },\n    \"duration_days\": {\n      \"type\": \"string\",\n      \"description\": \"Expected suspension duration in days\"\n    }\n  },\n  \"required\": [\n    \"employee_id\",\n    \"reason\"\n  ],\n  \"additionalProperties\": false\n}"
