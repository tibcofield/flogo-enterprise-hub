          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "suspend_user",
            "handlerDescription": "Temporarily suspend a user account across all systems. The user cannot log in but their data and permissions are preserved for reactivation. Commonly used for leaves of absence or investigations.",
