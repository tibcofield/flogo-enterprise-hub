{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-mcp/src/app/MCP/trigger/mcpserver",
    "github.com/project-flogo/contrib/function/coerce",
    "github.com/project-flogo/contrib/function/string"
  ],
  "name": "InfraMonitoringMCPServer",
  "description": "MCP server exposing 50 infrastructure monitoring tools covering server metrics, service health, alerts, networking, databases, containers, cloud resources, and capacity forecasting.",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#mcpserver",
      "name": "flogo-mcp-mcpsever",
      "description": "MCP server exposing InfraMonitoringMCPServer tools",
      "settings": {
        "serverName": "InfraMonitoringMCPServer",
        "serverVersion": "1.0.0",
        "serverType": "HTTP",
        "serverPort": "=$property[\"FlogoMcpServer.PORT\"]",
        "statelessServer": false,
        "serverEndpointPath": "/mcp",
        "enableTLS": false,
        "serverCertificate": "",
        "serverPrivateKey": "",
        "authType": "None",
        "authToken": ""
      },
      "id": "InfraMonitoringMCPServer",
      "handlers": [
        {
          "description": "Get current CPU, memory, disk, and network metrics for a server",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "get_server_metrics",
            "handlerDescription": "Get real-time CPU, memory, disk, and network utilization metrics for a specified server. Returns current values, averages, and threshold status for alerting.",
            "readOnlyToolHint": false,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": true
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:get_server_metrics"
            },
            "input": {
              "arguments": "=$.arguments"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"server_name\": {\n      \"type\": \"string\",\n      \"description\": \"Server hostname or IP address\"\n    }\n  },\n  \"required\": [\n    \"server_name\"\n  ],\n  \"additionalProperties\": false\n}",
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"server_name\": {\n      \"type\": \"string\",\n      \"description\": \"Server hostname or IP address\"\n    }\n  },\n  \"required\": [\n    \"server_name\"\n  ],\n  \"additionalProperties\": false\n}"
              }
            }
          },
          "name": "get_server_metrics"
        },
