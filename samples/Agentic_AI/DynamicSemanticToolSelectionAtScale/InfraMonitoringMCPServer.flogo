                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"datacenter\": {\n      \"type\": \"string\",\n      \"description\": \"Filter by datacenter name\"\n    },\n    \"environment\": {\n      \"type\": \"string\",\n      \"description\": \"Filter by environment: production, staging, development\"\n    },\n    \"status\": {\n      \"type\": \"string\",\n      \"description\": \"Filter by status: healthy, warning, critical, all. Default: all\"\n    }\n  },\n  \"required\": [],\n  \"additionalProperties\": false\n}",
