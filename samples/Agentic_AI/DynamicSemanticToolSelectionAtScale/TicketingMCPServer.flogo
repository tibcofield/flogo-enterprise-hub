              }
            }
          },
          "name": "update_ticket"
        },
        {
          "description": "Clone an existing ticket as a new ticket",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "clone_ticket",
            "handlerDescription": "Create a copy of an existing ticket with a new ticket ID. Copies title, description, category, and priority but resets status to Open. Useful for recurring issues.",
