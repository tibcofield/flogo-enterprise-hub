                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"ticket_id\": {\n      \"type\": \"string\",\n      \"description\": \"Source ticket ID to clone\"\n    },\n    \"new_title\": {\n      \"type\": \"string\",\n      \"description\": \"Optional new title for the cloned ticket\"\n    }\n  },\n  \"required\": [\n    \"ticket_id\"\n  ],\n  \"additionalProperties\": false\n}"
