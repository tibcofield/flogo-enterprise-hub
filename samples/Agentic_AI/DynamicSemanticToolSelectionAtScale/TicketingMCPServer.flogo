{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/tibco/flogo-general/src/app/General/activity/log",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-mcp/src/app/MCP/trigger/mcpserver",
    "github.com/project-flogo/contrib/function/coerce",
    "github.com/project-flogo/contrib/function/string"
  ],
  "name": "TicketingMCPServer",
  "description": "MCP server exposing 50 IT ticketing tools covering ticket lifecycle, assignment, status management, search, comments, attachments, SLA tracking, templates, approvals, and reporting.",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#mcpserver",
      "name": "flogo-mcp-mcpsever",
      "description": "MCP server exposing TicketingMCPServer tools",
      "settings": {
        "serverName": "TicketingMCPServer",
        "serverVersion": "1.0.0",
        "serverType": "HTTP",
        "serverPort": "=$property[\"FlogoMcpServer.PORT\"]",
        "statelessServer": false,
        "serverEndpointPath": "/mcp",
        "enableTLS": false,
        "serverCertificate": "",
        "serverPrivateKey": "",
        "authType": "None",
        "authToken": ""
      },
      "id": "TicketingMCPServer",
      "handlers": [
        {
          "description": "Get the current status and details of a support ticket",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "get_ticket_status",
            "handlerDescription": "Get the current status and full details of a support ticket including title, description, priority, assignee, category, SLA status, and all updates.",
            "readOnlyToolHint": false,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": true
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:get_ticket_status"
            },
            "input": {
              "arguments": "=$.arguments"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"ticket_id\": {\n      \"type\": \"string\",\n      \"description\": \"Support ticket ID\"\n    }\n  },\n  \"required\": [\n    \"ticket_id\"\n  ],\n  \"additionalProperties\": false\n}",
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"ticket_id\": {\n      \"type\": \"string\",\n      \"description\": \"Support ticket ID\"\n    }\n  },\n  \"required\": [\n    \"ticket_id\"\n  ],\n  \"additionalProperties\": false\n}"
              }
            }
          },
          "name": "get_ticket_status"
        },
        {
          "description": "Create a new support ticket",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "create_ticket",
            "handlerDescription": "Create a new IT support ticket with title, description, category, and priority. Auto-assigns based on category routing rules and sends confirmation to the requester.",
            "readOnlyToolHint": false,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": true
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:create_ticket"
            },
            "input": {
              "arguments": "=$.arguments"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"employee_id\": {\n      \"type\": \"string\",\n      \"description\": \"Employee ID creating the ticket\"\n    },\n    \"title\": {\n      \"type\": \"string\",\n      \"description\": \"Short title describing the issue\"\n    },\n    \"description\": {\n      \"type\": \"string\",\n      \"description\": \"Detailed description of the issue\"\n    },\n    \"category\": {\n      \"type\": \"string\",\n      \"description\": \"Ticket category: Hardware, Software, Network Access, Account, Email, Other\"\n    },\n    \"priority\": {\n      \"type\": \"string\",\n      \"description\": \"Priority level: Critical, High, Medium, Low. Default: Medium\"\n    }\n  },\n  \"required\": [\n    \"employee_id\",\n    \"title\",\n    \"description\",\n    \"category\"\n  ],\n  \"additionalProperties\": false\n}",
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"employee_id\": {\n      \"type\": \"string\",\n      \"description\": \"Employee ID creating the ticket\"\n    },\n    \"title\": {\n      \"type\": \"string\",\n      \"description\": \"Short title describing the issue\"\n    },\n    \"description\": {\n      \"type\": \"string\",\n      \"description\": \"Detailed description of the issue\"\n    },\n    \"category\": {\n      \"type\": \"string\",\n      \"description\": \"Ticket category: Hardware, Software, Network Access, Account, Email, Other\"\n    },\n    \"priority\": {\n      \"type\": \"string\",\n      \"description\": \"Priority level: Critical, High, Medium, Low. Default: Medium\"\n    }\n  },\n  \"required\": [\n    \"employee_id\",\n    \"title\",\n    \"description\",\n    \"category\"\n  ],\n  \"additionalProperties\": false\n}"
              }
            }
          },
          "name": "create_ticket"
        },
        {
          "description": "Update ticket fields like title, description, or category",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "update_ticket",
            "handlerDescription": "Update one or more fields of an existing support ticket. Supports updating title, description, category, tags, and custom fields. All changes are recorded in the ticket history.",
            "readOnlyToolHint": false,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": true
          },
          "action": {
