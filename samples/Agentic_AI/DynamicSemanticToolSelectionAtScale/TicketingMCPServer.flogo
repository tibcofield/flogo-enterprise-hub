        {
          "description": "Merge duplicate tickets into one",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "merge_tickets",
            "handlerDescription": "Merge two or more duplicate tickets into a single primary ticket. Comments and attachments from secondary tickets are moved to the primary. Secondary tickets are marked as Duplicate.",
            "readOnlyToolHint": false,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": true
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:merge_tickets"
            },
            "input": {
              "arguments": "=$.arguments"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"primary_ticket_id\": {\n      \"type\": \"string\",\n      \"description\": \"Ticket ID to keep as the primary\"\n    },\n    \"secondary_ticket_ids\": {\n      \"type\": \"string\",\n      \"description\": \"Comma-separated list of ticket IDs to merge into the primary\"\n    }\n  },\n  \"required\": [\n    \"primary_ticket_id\",\n    \"secondary_ticket_ids\"\n  ],\n  \"additionalProperties\": false\n}",
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"primary_ticket_id\": {\n      \"type\": \"string\",\n      \"description\": \"Ticket ID to keep as the primary\"\n    },\n    \"secondary_ticket_ids\": {\n      \"type\": \"string\",\n      \"description\": \"Comma-separated list of ticket IDs to merge into the primary\"\n    }\n  },\n  \"required\": [\n    \"primary_ticket_id\",\n    \"secondary_ticket_ids\"\n  ],\n  \"additionalProperties\": false\n}"
              }
