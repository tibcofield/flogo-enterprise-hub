{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-mcp/src/app/MCP/trigger/mcpserver",
    "github.com/project-flogo/contrib/function/string"
  ],
  "name": "PolicyLookupMCPServer",
  "description": "Stateless MCP server exposing insurance policy lookup and coverage check tools.",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#mcpserver",
      "name": "flogo-mcp-mcpsever",
      "description": "Stateless MCP server for insurance policy lookups. Each tool call is independent.",
      "settings": {
        "serverName": "PolicyLookupMCPServer",
        "serverVersion": "1.0.0",
        "serverType": "HTTP",
        "serverPort": "=$property[\"FlogoMcpServer.PORT\"]",
        "statelessServer": true,
        "serverEndpointPath": "/mcp",
        "enableTLS": false,
        "serverCertificate": "",
        "serverPrivateKey": "",
        "authType": "JWT Token",
        "authToken": "=$property[\"FlogoMcpServer.JWT_Secret\"]"
      },
      "id": "PolicyLookupMCPServer",
      "handlers": [
        {
          "description": "Read-only policy details lookup.",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "lookup_policy",
            "handlerDescription": "Retrieve full insurance policy details by policy number. Returns policy type, coverage limits, deductible, premium, policy holder information, effective dates, and current status. Read-only lookup — no state is modified.",
            "readOnlyToolHint": true,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:lookup_policy_flow"
            },
            "input": {
              "arguments": "=$.arguments",
              "httpHeaders": "=$.httpHeaders",
              "tokenInfo": "=$.tokenInfo"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"policy_number\": {\n      \"type\": \"string\",\n      \"description\": \"The insurance policy number (e.g. POL-2026-001234)\"\n    }\n  },\n  \"required\": [\"policy_number\"],\n  \"additionalProperties\": false\n}",
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"policy_number\": {\n      \"type\": \"string\",\n      \"description\": \"The insurance policy number (e.g. POL-2026-001234)\"\n    }\n  },\n  \"required\": [\"policy_number\"],\n  \"additionalProperties\": false\n}"
              },
              "httpHeaders": {
                "type": "json",
                "value": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"Authorization\": {\n      \"type\": \"string\"\n    }\n  }\n}",
                "fe_metadata": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"Authorization\": {\n      \"type\": \"string\"\n    }\n  }\n}"
              },
              "tokenInfo": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"scopes\": {\r\n      \"type\": \"array\",\r\n      \"items\": [\r\n        {\r\n          \"type\": \"string\"\r\n        }\r\n      ]\r\n    },\r\n    \"expiration\": {\r\n      \"type\": \"number\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"scopes\": {\r\n      \"type\": \"array\",\r\n      \"items\": [\r\n        {\r\n          \"type\": \"string\"\r\n        }\r\n      ]\r\n    },\r\n    \"expiration\": {\r\n      \"type\": \"number\"\r\n    }\r\n  }\r\n}"
              }
            }
          },
          "name": "lookup_policy_flow"
        },
        {
          "description": "Read-only coverage check.",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "check_coverage",
            "handlerDescription": "Check whether a specific claim type is covered under an insurance policy. Returns coverage status (COVERED/NOT_COVERED/PARTIALLY_COVERED), applicable coverage limit, deductible amount, co-pay percentage, and any exclusions or conditions. Read-only, closed-domain.",
            "readOnlyToolHint": true,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": false
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:check_coverage_flow"
            },
            "input": {
              "arguments": "=$.arguments",
              "httpHeaders": "=$.httpHeaders",
              "tokenInfo": "=$.tokenInfo"
            },
            "output": {
              "response": "=$.response",
              "structuredContent": "=$.structuredContent"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"policy_number\": {\n      \"type\": \"string\",\n      \"description\": \"The insurance policy number\"\n    },\n    \"claim_type\": {\n      \"type\": \"string\",\n      \"description\": \"Type of claim to check coverage for (e.g. collision, theft, medical, property_damage, liability, natural_disaster)\"\n    }\n  },\n  \"required\": [\"policy_number\", \"claim_type\"],\n  \"additionalProperties\": false\n}",
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"policy_number\": {\n      \"type\": \"string\",\n      \"description\": \"The insurance policy number\"\n    },\n    \"claim_type\": {\n      \"type\": \"string\",\n      \"description\": \"Type of claim to check coverage for (e.g. collision, theft, medical, property_damage, liability, natural_disaster)\"\n    }\n  },\n  \"required\": [\"policy_number\", \"claim_type\"],\n  \"additionalProperties\": false\n}"
              },
              "httpHeaders": {
                "type": "json",
                "value": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"Authorization\": {\n      \"type\": \"string\"\n    }\n  }\n}",
                "fe_metadata": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"Authorization\": {\n      \"type\": \"string\"\n    }\n  }\n}"
              },
              "tokenInfo": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"scopes\": {\r\n      \"type\": \"array\",\r\n      \"items\": [\r\n        {\r\n          \"type\": \"string\"\r\n        }\r\n      ]\r\n    },\r\n    \"expiration\": {\r\n      \"type\": \"number\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"scopes\": {\r\n      \"type\": \"array\",\r\n      \"items\": [\r\n        {\r\n          \"type\": \"string\"\r\n        }\r\n      ]\r\n    },\r\n    \"expiration\": {\r\n      \"type\": \"number\"\r\n    }\r\n  }\r\n}"
              }
            }
          },
          "name": "check_coverage_flow"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:lookup_policy_flow",
      "data": {
        "name": "lookup_policy_flow",
        "description": "Read-only policy details lookup.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "Return",
            "type": "label",
            "label": "StartActivity to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Returns mock policy data.",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "structuredContent": {
                    "mapping": {
                      "policyNumber": "=$flow.arguments.policy_number",
                      "policyType": "Comprehensive Auto",
                      "status": "ACTIVE",
                      "holderName": "Robert Chen",
                      "holderEmail": "robert.chen@email.com",
                      "effectiveDate": "2026-01-15",
                      "expirationDate": "2027-01-15",
                      "deductible": 1000,
                      "monthlyPremium": 185,
                      "collisionLimit": 50000,
                      "comprehensiveLimit": 50000,
                      "liabilityLimit": 100000,
                      "medicalLimit": 10000,
                      "vehicleMake": "Toyota",
                      "vehicleModel": "Camry",
                      "vehicleYear": 2024
                    }
                  },
                  "response": {
                    "@conditional": [
                      {
                        "$flow.arguments.policy_number != ''": {
                          "data": "=string.concat(\"{\\\"policyNumber\\\":\\\"\",$flow.arguments.policy_number,\"\\\",\\\"policyType\\\":\\\"Comprehensive Auto\\\",\\\"status\\\":\\\"ACTIVE\\\",\\\"holder\\\":{\\\"name\\\":\\\"Robert Chen\\\",\\\"dateOfBirth\\\":\\\"1985-03-22\\\",\\\"address\\\":\\\"456 Oak Avenue, Portland OR 97201\\\",\\\"phone\\\":\\\"503-555-0147\\\",\\\"email\\\":\\\"robert.chen@email.com\\\"},\\\"vehicle\\\":{\\\"make\\\":\\\"Toyota\\\",\\\"model\\\":\\\"Camry\\\",\\\"year\\\":2024,\\\"vin\\\":\\\"4T1G11AK5RU123456\\\"},\\\"effectiveDate\\\":\\\"2026-01-15\\\",\\\"expirationDate\\\":\\\"2027-01-15\\\",\\\"coverageLimits\\\":{\\\"collision\\\":50000,\\\"comprehensive\\\":50000,\\\"liability\\\":100000,\\\"medical\\\":10000,\\\"uninsured_motorist\\\":50000},\\\"deductible\\\":1000,\\\"monthlyPremium\\\":185.00,\\\"claimHistory\\\":[{\\\"claimId\\\":\\\"CLM-2026-8891\\\",\\\"date\\\":\\\"2026-03-10\\\",\\\"type\\\":\\\"collision\\\",\\\"amount\\\":3200,\\\"status\\\":\\\"SETTLED\\\"}],\\\"discounts\\\":[\\\"Safe driver\\\",\\\"Multi-policy\\\",\\\"Anti-theft device\\\"]}\")"
                        }
                      },
                      {
                        "@otherwise": {
                          "error": "policy_number is required"
                        }
                      }
                    ]
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIlJldHVybiI6eyJ4IjoyNTAsInkiOjUwfX0=",
        "metadata": {
          "input": [
            {
              "name": "arguments",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"policy_number\":{\"type\":\"string\",\"description\":\"The insurance policy number (e.g. POL-2026-001234)\"}}"
              }
            },
            {
              "name": "httpHeaders",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"Authorization\":{\"type\":\"string\"}}"
              }
            },
            {
              "name": "tokenInfo",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"scopes\":{\"type\":\"array\",\"items\":[{\"type\":\"string\"}]},\"expiration\":{\"type\":\"number\"}}"
              }
            }
          ],
          "output": [
            {
              "name": "response",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"data\":{\"type\":\"string\"},\"error\":{\"type\":\"string\"}}"
              }
            }
          ],
          "fe_metadata": {
            "input": "{\"type\":\"object\",\"title\":\"PolicyLookupMCPServer\",\"properties\":{\"arguments\":{\"$schema\":\"http://json-schema.org/draft-07/schema#\",\"type\":\"object\",\"properties\":{\"policy_number\":{\"type\":\"string\",\"description\":\"The insurance policy number (e.g. POL-2026-001234)\"}},\"required\":[\"policy_number\"],\"additionalProperties\":false},\"httpHeaders\":{\"type\":\"object\",\"properties\":{\"Authorization\":{\"type\":\"string\"}}},\"tokenInfo\":{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"scopes\":{\"type\":\"array\",\"items\":[{\"type\":\"string\"}]},\"expiration\":{\"type\":\"number\"}}}}}",
            "output": "{\"type\":\"object\",\"title\":\"Inputs\",\"properties\":{\"response\":{\"type\":\"object\",\"properties\":{\"data\":{\"type\":\"string\"},\"error\":{\"type\":\"string\"}}}},\"required\":[\"response\"]}"
          }
        }
      }
    },
    {
      "id": "flow:check_coverage_flow",
      "data": {
        "name": "check_coverage_flow",
        "description": "Read-only coverage check.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "Return",
            "type": "label",
            "label": "StartActivity to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Returns mock coverage check.",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "structuredContent": {
                    "mapping": {
                      "policyNumber": "=$flow.arguments.policy_number",
                      "claimType": "=$flow.arguments.claim_type",
                      "coverageStatus": "COVERED",
                      "coverageLimit": 50000,
                      "deductible": 1000,
                      "coPayPercentage": 20,
                      "priorAuthorization": false,
                      "estimatedProcessingDays": 10
                    }
                  },
                  "response": {
                    "@conditional": [
                      {
                        "$flow.arguments.policy_number != '' && $flow.arguments.claim_type != ''": {
                          "data": "=string.concat(\"{\\\"policyNumber\\\":\\\"\",$flow.arguments.policy_number,\"\\\",\\\"claimType\\\":\\\"\",$flow.arguments.claim_type,\"\\\",\\\"coverageStatus\\\":\\\"COVERED\\\",\\\"coverageLimit\\\":50000,\\\"deductible\\\":1000,\\\"coPayPercentage\\\":20,\\\"exclusions\\\":[\\\"Intentional damage\\\",\\\"Racing or speed contests\\\",\\\"Commercial use of vehicle\\\"],\\\"conditions\\\":[\\\"Police report required for claims over $2,000\\\",\\\"Photos of damage must be submitted within 72 hours\\\",\\\"Rental car coverage limited to 30 days\\\"],\\\"priorAuthorization\\\":false,\\\"estimatedProcessingDays\\\":10}\")"
                        }
                      },
                      {
                        "@otherwise": {
                          "error": "Both policy_number and claim_type are required"
                        }
                      }
                    ]
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIlJldHVybiI6eyJ4IjoyNTAsInkiOjE1MH19",
        "metadata": {
          "input": [
            {
              "name": "arguments",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"policy_number\":{\"type\":\"string\"},\"claim_type\":{\"type\":\"string\"}}"
              }
            },
            {
              "name": "httpHeaders",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"Authorization\":{\"type\":\"string\"}}"
              }
            },
            {
              "name": "tokenInfo",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"scopes\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"expiration\":{\"type\":\"number\"},\"iss\":{\"type\":\"string\"},\"sub\":{\"type\":\"string\"},\"aud\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"name\":{\"type\":\"string\"},\"email\":{\"type\":\"string\"}}"
              }
            }
          ],
          "output": [
            {
              "name": "response",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"data\":{\"type\":\"string\"},\"error\":{\"type\":\"string\"}}"
              }
            },
            {
              "name": "structuredContent",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"policyNumber\":{\"type\":\"string\"},\"claimType\":{\"type\":\"string\"},\"coverageStatus\":{\"type\":\"string\"},\"coverageLimit\":{\"type\":\"number\"},\"deductible\":{\"type\":\"number\"},\"coPayPercentage\":{\"type\":\"number\"},\"priorAuthorization\":{\"type\":\"boolean\"},\"estimatedProcessingDays\":{\"type\":\"integer\"}}"
              }
            }
          ],
          "fe_metadata": {
            "input": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"arguments\":{\"type\":\"object\",\"properties\":{\"policy_number\":{\"type\":\"string\"},\"claim_type\":{\"type\":\"string\"}}},\"httpHeaders\":{\"type\":\"object\",\"properties\":{\"Authorization\":{\"type\":\"string\"}}},\"tokenInfo\":{\"type\":\"object\",\"properties\":{\"scopes\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"expiration\":{\"type\":\"number\"},\"iss\":{\"type\":\"string\"},\"sub\":{\"type\":\"string\"},\"aud\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"name\":{\"type\":\"string\"},\"email\":{\"type\":\"string\"}}}}}",
            "output": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"response\":{\"type\":\"object\",\"properties\":{\"data\":{\"type\":\"string\"},\"error\":{\"type\":\"string\"}}},\"structuredContent\":{\"type\":\"object\",\"properties\":{\"policyNumber\":{\"type\":\"string\"},\"claimType\":{\"type\":\"string\"},\"coverageStatus\":{\"type\":\"string\"},\"coverageLimit\":{\"type\":\"number\"},\"deductible\":{\"type\":\"number\"},\"coPayPercentage\":{\"type\":\"number\"},\"priorAuthorization\":{\"type\":\"boolean\"},\"estimatedProcessingDays\":{\"type\":\"integer\"}}}}}"
          }
        }
      }
    }
  ],
  "properties": [
