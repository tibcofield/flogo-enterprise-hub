{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/trigger/agent",
    "github.com/project-flogo/contrib/function/string",
    "github.com/tibco/flogo-ai-agent/src/app/AgenticAI/connector/llmprovider"
  ],
  "name": "FraudDetectionA2A",
  "description": "A2A Server agent for insurance fraud detection. Analyzes claim patterns and calculates risk scores.",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#agent",
      "name": "flogo-agenticai-agent",
      "description": "Fraud detection A2A Server agent on port 9504.",
      "settings": {
        "llmProviderConnection": "conn://da22bbbb-cccc-dddd-eeee-ffff00000020",
        "agentName": "=$property[\"Trigger_Settings.AgentName\"]",
        "agentDescription": "=$property[\"Trigger_Settings.AgentDescription\"]",
        "agentType": "A2A Server",
        "agentPort": "9604",
        "agentUrl": "=$property[\"A2A.AgentUrl\"]",
        "agentAuthMode": "Static Token",
        "agentToken": "=$property[\"A2A.AuthToken\"]",
        "model": "=$property[\"Trigger_Settings.LLM_Model\"]",
        "reasoning": "",
        "temperature": "=$property[\"Trigger_Settings.LLM_temperature\"]",
        "enableGuardrails": false,
        "rateLimit": "=$property[\"Trigger_Settings.Rate_Limit\"]",
        "tokenLimit": "=$property[\"Trigger_Settings.Token_Limit\"]",
        "redactSensitiveData": true,
        "remoteAgents": [],
        "mcpServers": [],
        "conversationStoreType": "Memory",
        "memoryMaxSize": 20,
        "systemPrompt": "You are a fraud detection specialist agent exposed via the A2A protocol. You serve insurance claims orchestrator agents that need expert fraud intelligence to evaluate incoming claims.\n\n## Your Capabilities\n\n- **AnalyzeClaimPatterns**: Check for suspicious patterns in insurance claims including claim frequency anomalies, timing irregularities, amount outliers, and location-based red flags. Returns a detailed pattern analysis with suspicious indicators and an overall risk assessment.\n- **CalculateRiskScore**: Calculate a composite fraud risk score (0-100) for an insurance claim based on multiple fraud dimensions. Returns a detailed score breakdown across claim frequency, amount anomaly, document consistency, and behavioral pattern categories, along with a recommendation.\n\n## Behavior Rules\n\n- You are a decision-support tool. Always present fraud findings neutrally and factually.\n- A 'HIGH_RISK' assessment does not mandate claim denial — claims adjusters make the final call.\n- Never fabricate risk scores or invent claimant data. If a lookup fails, say so clearly.\n- When called by an orchestrator agent, return structured JSON-friendly summaries that the caller can relay to its end user.\n- Present tabular data in markdown tables.\n- Cite the specific tool results that support each fraud conclusion.\n- Protect claimant privacy — never expose raw personal data beyond what is necessary for the fraud assessment."
      },
      "id": "FraudDetectionA2AServer",
      "handlers": [
        {
          "description": "Analyzes claim patterns for fraud indicators.",
          "settings": {
            "handlerType": "Tool",
            "agentToolName": "AnalyzeClaimPatterns",
            "agentToolDescription": "Analyze an insurance claim for suspicious patterns including claim frequency anomalies, timing irregularities, amount outliers, and location-based red flags. Returns an analysis ID, list of detected patterns with severity ratings, suspicious indicators, and an overall risk assessment (LOW_RISK/MEDIUM_RISK/HIGH_RISK). Used by claims processing orchestrators to flag potentially fraudulent claims.",
            "agentSkillTags": "AnalyzeClaimPatterns,fraud,insurance,claims,pattern_analysis,risk_assessment",
            "agentSkillExamples": "Analyze claim patterns for claimant John Doe on policy POL-12345 with a $15,000 auto collision claim.|Check for suspicious patterns on a $50,000 property damage claim filed by Jane Smith, policy POL-67890.|Run pattern analysis on a medical claim of $8,500 for claimant Bob Wilson, policy POL-11111.|Investigate claim frequency for claimant Alice Brown, policy POL-99999, who filed 3 claims this year.|Analyze a $25,000 theft claim from an unusual location for claimant Carlos Garcia, policy POL-55555.",
            "customGuardrailType": "BOTH",
            "customConversationStoreOperation": "STORE"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:analyze_claim_patterns_flow"
            },
            "input": {
              "toolParams": "=$.toolParams"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"data\": {\n      \"type\": \"string\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  }\n}",
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"data\": {\n      \"type\": \"string\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  }\n}"
              },
              "customConversationStoreOpOutput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}"
              }
            },
            "output": {
              "toolParams": {
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"claimantName\": {\n      \"type\": \"string\",\n      \"description\": \"Name of the claimant filing the insurance claim\"\n    },\n    \"policyNumber\": {\n      \"type\": \"string\",\n      \"description\": \"Insurance policy number associated with the claim\"\n    },\n    \"claimType\": {\n      \"type\": \"string\",\n      \"description\": \"Type of insurance claim (e.g., auto_collision, property_damage, medical, theft, liability)\"\n    },\n    \"claimAmount\": {\n      \"type\": \"number\",\n      \"description\": \"Dollar amount of the insurance claim\"\n    },\n    \"incidentDate\": {\n      \"type\": \"string\",\n      \"description\": \"Date of the incident in ISO 8601 format\"\n    },\n    \"incidentDescription\": {\n      \"type\": \"string\",\n      \"description\": \"Brief description of the incident leading to the claim\"\n    }\n  },\n  \"required\": [\"claimantName\", \"policyNumber\"]\n}",
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"claimantName\": {\n      \"type\": \"string\",\n      \"description\": \"Name of the claimant filing the insurance claim\"\n    },\n    \"policyNumber\": {\n      \"type\": \"string\",\n      \"description\": \"Insurance policy number associated with the claim\"\n    },\n    \"claimType\": {\n      \"type\": \"string\",\n      \"description\": \"Type of insurance claim (e.g., auto_collision, property_damage, medical, theft, liability)\"\n    },\n    \"claimAmount\": {\n      \"type\": \"number\",\n      \"description\": \"Dollar amount of the insurance claim\"\n    },\n    \"incidentDate\": {\n      \"type\": \"string\",\n      \"description\": \"Date of the incident in ISO 8601 format\"\n    },\n    \"incidentDescription\": {\n      \"type\": \"string\",\n      \"description\": \"Brief description of the incident leading to the claim\"\n    }\n  },\n  \"required\": [\"claimantName\", \"policyNumber\"]\n}"
              },
              "customGuardrailInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}"
              },
              "customConversationStoreOpInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}"
              }
            }
          },
          "name": "analyze_claim_patterns_flow"
        },
        {
          "description": "Calculates composite fraud risk score.",
          "settings": {
            "handlerType": "Tool",
            "agentToolName": "CalculateRiskScore",
            "agentToolDescription": "Calculate a composite fraud risk score (0-100) for an insurance claim based on multiple fraud dimensions including claim frequency, amount anomaly, document consistency, and behavioral patterns. Returns a risk score ID, composite score, detailed score breakdown by category, a recommendation (APPROVE/FLAG_FOR_REVIEW/DENY), and a confidence level (0-1). Used by claims adjusters and underwriting orchestrators for fraud risk quantification.",
            "agentSkillTags": "CalculateRiskScore,fraud_score,risk,insurance,claims,quantification",
            "agentSkillExamples": "Calculate fraud risk score for claimant John Doe, policy POL-12345, with pattern analysis PA-2026-10001.|What is the fraud risk score for a $50,000 property claim by Jane Smith, policy POL-67890?|Run risk scoring on claimant Bob Wilson's medical claim, policy POL-11111, amount $8,500.|Calculate composite fraud score for claimant Alice Brown, policy POL-99999, based on prior pattern analysis.|Quantify fraud risk for a high-value theft claim by Carlos Garcia, policy POL-55555.",
            "customGuardrailType": "BOTH",
            "customConversationStoreOperation": "STORE"
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:calculate_risk_score_flow"
            },
            "input": {
              "toolParams": "=$.toolParams"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"data\": {\n      \"type\": \"string\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  }\n}",
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"data\": {\n      \"type\": \"string\"\n    },\n    \"error\": {\n      \"type\": \"string\"\n    }\n  }\n}"
              },
              "customConversationStoreOpOutput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"success\"\r\n  ]\r\n}"
              }
            },
            "output": {
              "toolParams": {
                "type": "json",
                "value": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"claimantName\": {\n      \"type\": \"string\",\n      \"description\": \"Name of the claimant\"\n    },\n    \"policyNumber\": {\n      \"type\": \"string\",\n      \"description\": \"Insurance policy number\"\n    },\n    \"patternAnalysisId\": {\n      \"type\": \"string\",\n      \"description\": \"ID of a prior pattern analysis from AnalyzeClaimPatterns\"\n    },\n    \"claimAmount\": {\n      \"type\": \"number\",\n      \"description\": \"Dollar amount of the insurance claim\"\n    }\n  },\n  \"required\": [\"claimantName\", \"policyNumber\"]\n}",
                "fe_metadata": "{\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"claimantName\": {\n      \"type\": \"string\",\n      \"description\": \"Name of the claimant\"\n    },\n    \"policyNumber\": {\n      \"type\": \"string\",\n      \"description\": \"Insurance policy number\"\n    },\n    \"patternAnalysisId\": {\n      \"type\": \"string\",\n      \"description\": \"ID of a prior pattern analysis from AnalyzeClaimPatterns\"\n    },\n    \"claimAmount\": {\n      \"type\": \"number\",\n      \"description\": \"Dollar amount of the insurance claim\"\n    }\n  },\n  \"required\": [\"claimantName\", \"policyNumber\"]\n}"
              },
              "customGuardrailInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"isRequest\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"data\",\"isRequest\"\r\n ]\r\n}"
              },
              "customConversationStoreOpInput": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-04/schema#\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"conversationId\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"message\": {\r\n      \"type\": \"object\",\r\n      \"properties\": {\r\n        \"role\": {\r\n          \"type\": \"string\",\r\n          \"enum\":[\"user\", \"assistant\", \"system\", \"tool\"]\r\n        },\r\n        \"content\": {\r\n          \"type\": \"string\"\r\n        },\r\n        \"metadata\": {\r\n          \"type\": \"object\"\r\n        }\r\n      },\r\n      \"required\": [\r\n        \"role\",\r\n        \"content\",\r\n        \"metadata\"\r\n      ]\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"conversationId\",\r\n    \"message\"\r\n  ]\r\n}"
              }
            }
          },
          "name": "calculate_risk_score_flow"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:analyze_claim_patterns_flow",
      "data": {
        "name": "analyze_claim_patterns_flow",
        "description": "Analyzes claim patterns for fraud indicators.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "Return",
            "type": "label",
            "label": "StartActivity to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Returns mock claim pattern analysis.",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "response": {
                    "mapping": {
                      "data": "=string.concat(\"{\\\"analysisId\\\":\\\"PA-2026-10001\\\",\\\"claimantName\\\":\\\"\",$flow.toolParams.claimantName,\"\\\",\\\"policyNumber\\\":\\\"\",$flow.toolParams.policyNumber,\"\\\",\\\"patternsFound\\\":[{\\\"pattern\\\":\\\"CLAIM_FREQUENCY\\\",\\\"description\\\":\\\"3 claims filed in the past 12 months, exceeding the policy average of 0.8 claims per year\\\",\\\"severity\\\":\\\"MEDIUM\\\"},{\\\"pattern\\\":\\\"AMOUNT_ANOMALY\\\",\\\"description\\\":\\\"Claim amount is 2.4x the average for this claim type and coverage tier\\\",\\\"severity\\\":\\\"HIGH\\\"},{\\\"pattern\\\":\\\"TIMING_PATTERN\\\",\\\"description\\\":\\\"Claim filed within 45 days of policy renewal, matching a known staging pattern\\\",\\\"severity\\\":\\\"MEDIUM\\\"}],\\\"suspiciousIndicators\\\":[\\\"Multiple claims across different coverage types in short timeframe\\\",\\\"Incident description lacks specific details and timestamps\\\",\\\"Claim amount just below the threshold requiring independent adjuster review\\\"],\\\"overallAssessment\\\":\\\"MEDIUM_RISK\\\",\\\"claimsHistoryCount\\\":3,\\\"averageClaimAmount\\\":12500,\\\"timestamp\\\":\\\"2026-06-02T10:00:00Z\\\"}\")",
                      "error": ""
                    }
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIlJldHVybiI6eyJ4IjoyNTAsInkiOjUwfX0=",
        "metadata": {
          "input": [
            {
              "name": "toolParams",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"claimantName\":{\"type\":\"string\",\"description\":\"Name of the claimant filing the insurance claim\"},\"policyNumber\":{\"type\":\"string\",\"description\":\"Insurance policy number associated with the claim\"},\"claimType\":{\"type\":\"string\",\"description\":\"Type of insurance claim (e.g., auto_collision, property_damage, medical, theft, liability)\"},\"claimAmount\":{\"type\":\"number\",\"description\":\"Dollar amount of the insurance claim\"},\"incidentDate\":{\"type\":\"string\",\"description\":\"Date of the incident in ISO 8601 format\"},\"incidentDescription\":{\"type\":\"string\",\"description\":\"Brief description of the incident leading to the claim\"}}"
              }
            }
          ],
          "output": [
            {
              "name": "response",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"data\":{\"type\":\"string\"},\"error\":{\"type\":\"string\"}}"
              }
            }
          ],
          "fe_metadata": {
            "input": "{\"type\":\"object\",\"title\":\"FraudDetectionA2AServer\",\"properties\":{\"toolParams\":{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"claimantName\":{\"type\":\"string\",\"description\":\"Name of the claimant filing the insurance claim\"},\"policyNumber\":{\"type\":\"string\",\"description\":\"Insurance policy number associated with the claim\"},\"claimType\":{\"type\":\"string\",\"description\":\"Type of insurance claim (e.g., auto_collision, property_damage, medical, theft, liability)\"},\"claimAmount\":{\"type\":\"number\",\"description\":\"Dollar amount of the insurance claim\"},\"incidentDate\":{\"type\":\"string\",\"description\":\"Date of the incident in ISO 8601 format\"},\"incidentDescription\":{\"type\":\"string\",\"description\":\"Brief description of the incident leading to the claim\"}},\"required\":[\"claimantName\",\"policyNumber\"]}}}",
            "output": "{\"type\":\"object\",\"title\":\"Inputs\",\"properties\":{\"response\":{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"data\":{\"type\":\"string\"},\"error\":{\"type\":\"string\"}}}},\"required\":[]}"
          }
        }
      }
    },
    {
      "id": "flow:calculate_risk_score_flow",
      "data": {
        "name": "calculate_risk_score_flow",
        "description": "Calculates composite fraud risk score.",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "Return",
            "type": "label",
            "label": "StartActivity to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Returns mock fraud risk score.",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "response": {
                    "mapping": {
                      "data": "=string.concat(\"{\\\"riskScoreId\\\":\\\"RS-2026-20001\\\",\\\"claimantName\\\":\\\"\",$flow.toolParams.claimantName,\"\\\",\\\"policyNumber\\\":\\\"\",$flow.toolParams.policyNumber,\"\\\",\\\"compositeScore\\\":62,\\\"scoreBreakdown\\\":{\\\"claimFrequency\\\":{\\\"score\\\":58,\\\"weight\\\":0.25,\\\"details\\\":\\\"Above-average claim frequency detected in past 24 months\\\"},\\\"amountAnomaly\\\":{\\\"score\\\":74,\\\"weight\\\":0.30,\\\"details\\\":\\\"Claim amount significantly exceeds typical range for this coverage type\\\"},\\\"documentConsistency\\\":{\\\"score\\\":45,\\\"weight\\\":0.25,\\\"details\\\":\\\"Minor inconsistencies in incident timeline; supporting documents pending verification\\\"},\\\"behavioralPattern\\\":{\\\"score\\\":68,\\\"weight\\\":0.20,\\\"details\\\":\\\"Claim filed shortly after policy change and during known high-fraud period\\\"}},\\\"recommendation\\\":\\\"FLAG_FOR_REVIEW\\\",\\\"confidence\\\":0.78,\\\"riskFactors\\\":[\\\"Elevated claim frequency for policy age\\\",\\\"Amount exceeds 90th percentile for claim type\\\",\\\"Temporal correlation with policy modification\\\"],\\\"mitigatingFactors\\\":[\\\"Long-standing customer (5+ years)\\\",\\\"No prior fraud flags on record\\\"],\\\"timestamp\\\":\\\"2026-06-02T10:00:00Z\\\"}\")",
                      "error": ""
                    }
                  }
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIlJldHVybiI6eyJ4IjoyNjMsInkiOjU0fX0=",
        "metadata": {
          "input": [
            {
              "name": "toolParams",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"claimantName\":{\"type\":\"string\",\"description\":\"Name of the claimant\"},\"policyNumber\":{\"type\":\"string\",\"description\":\"Insurance policy number\"},\"patternAnalysisId\":{\"type\":\"string\",\"description\":\"ID of a prior pattern analysis from AnalyzeClaimPatterns\"},\"claimAmount\":{\"type\":\"number\",\"description\":\"Dollar amount of the insurance claim\"}}"
              }
            }
          ],
          "output": [
            {
