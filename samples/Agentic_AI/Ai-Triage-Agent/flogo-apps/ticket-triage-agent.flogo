      "type": "float64",
      "value": 60
    }
  ],
  "connections": {
    "075225de-9fdd-49f1-93cb-1cfffdd24b6b": {
      "id": "075225de-9fdd-49f1-93cb-1cfffdd24b6b",
      "name": "LLMConn",
      "ref": "#llmprovider",
      "isGlobal": false,
      "settings": {
        "name": "LLMConn",
        "description": "Your llmprovider Connector",
        "llmProvider": "=$property[\"AgenticAI.LLMConn.LLM_Provider\"]",
        "anthropicProvider": "Default",
        "apiKey": "=$property[\"AgenticAI.LLMConn.API_Key\"]",
        "llmProviderUrl": "=$property[\"AgenticAI.LLMConn.LLM_Base_URL\"]"
      }
    },
    "9ad67e43-f78e-4837-9f01-881d9036bcf0": {
      "id": "9ad67e43-f78e-4837-9f01-881d9036bcf0",
      "name": "SNMCPClient",
      "ref": "#mcpserverconfig",
      "isGlobal": false,
      "settings": {
        "name": "SNMCPClient",
        "description": "Your mcpserverconfig Connector",
        "serverType": "http",
        "serverUrl": "http://localhost:9090/mcp",
        "httpTransportType": "streamable",
        "authType": "None",
        "authToken": "",
        "selectedTools": [
          "append_occurrence",
          "fetch_incident",
          "reject_bad_data",
          "search_incidents",
          "create_incident",
          "search_past_resolutions",
          "update_incident_resolution"
        ]
      }
    }
  },
  "contrib": "",
  "metadata": {
    "endpoints": [
      {
        "protocol": "http",
        "port": "8080",
        "spec": {
          "name": "ticket-triage-agent",
          "version": "1.0.0"
        },
        "title": "TriageHTTPTrigger",
        "swagger": {
          "swagger": "2.0",
          "info": {
            "title": "ticket-triage-agent",
            "version": "1.0.0",
            "description": "Triage REST trigger (POST /triage)"
          },
          "paths": {
            "/triage": {
              "post": {
                "summary": "triage-main",
                "operationId": "post_triage",
                "parameters": [
                  {
                    "name": "Authorization",
                    "in": "header",
                    "description": "Request parameter",
                    "required": false,
                    "type": "string"
                  },
                  {
                    "name": "body",
                    "in": "body",
                    "description": "request body parameter",
                    "required": true,
                    "schema": {
                      "$ref": "#/definitions/schema1"
                    }
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Rest Response",
                    "schema": {
                      "$ref": "#/definitions/schema2"
                    }
                  }
                },
                "description": "Entry flow: log event, run agent with MCP tools, return decision",
                "consumes": [
                  "application/json"
                ]
              }
            }
          },
