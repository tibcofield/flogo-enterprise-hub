{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/tibco/flogo-general/src/app/General/activity/rest",
    "github.com/project-flogo/contrib/activity/actreturn",
    "github.com/tibco/flogo-mcp/src/app/MCP/trigger/mcpserver",
    "github.com/project-flogo/contrib/function/coerce",
    "git.tibco.com/git/product/ipaas/wi-contrib.git/function/boolean"
  ],
  "name": "sn-mcp-wrapper",
  "description": "MCP server wrapper over mock-servicenow. Exposes fetch/search/create/append/reject tools so the BW6 triage AI agent can call ServiceNow via MCP.",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#mcpserver",
      "name": "flogo-mcp-mcpsever",
      "description": "MCP server exposing ServiceNow tools to Agentic AI clients",
      "settings": {
        "serverName": "bw6-sn-mcp",
        "serverVersion": "1.0.0",
        "serverType": "HTTP",
        "serverPort": "9090",
        "statelessServer": false,
        "serverEndpointPath": "/mcp",
        "enableTLS": false,
        "serverCertificate": "",
        "serverPrivateKey": "",
        "authType": "None",
        "authToken": ""
      },
      "id": "SNMCPServer",
      "handlers": [
        {
          "description": "Fetch one incident by sys_id",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "fetch_incident",
            "handlerDescription": "Fetch one ServiceNow incident by sys_id. Returns the full incident record or 404.",
            "readOnlyToolHint": false,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": true
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:tool-fetch-incident"
            },
            "input": {
              "arguments": "=$.arguments",
              "httpHeaders": "=$.httpHeaders"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"sys_id\":{\"type\":\"string\"}},\"required\":[\"sys_id\"]}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"sys_id\":{\"type\":\"string\"}},\"required\":[\"sys_id\"]}"
              }
            }
          },
          "name": "tool-fetch-incident"
        },
        {
          "description": "Search open incidents by errorCode and appName within a window",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "search_incidents",
            "handlerDescription": "Search open ServiceNow incidents matching an errorCode and appName within a time window (minutes). Returns a list of candidate incidents with sys_id, short_description, u_error_code, u_app_name, u_app_node, u_process_name, opened_at, u_occurrence_count. Use this to decide NEW vs DUPLICATE_OF.",
            "readOnlyToolHint": false,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": true
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:tool-search-incidents"
            },
            "input": {
              "arguments": "=$.arguments",
              "httpHeaders": "=$.httpHeaders"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"errorCode\":{\"type\":\"string\"},\"appName\":{\"type\":\"string\"},\"window_min\":{\"type\":\"integer\"}},\"required\":[\"errorCode\",\"appName\"]}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"errorCode\":{\"type\":\"string\"},\"appName\":{\"type\":\"string\"},\"window_min\":{\"type\":\"integer\"}},\"required\":[\"errorCode\",\"appName\"]}"
              }
            }
          },
          "name": "tool-search-incidents"
        },
        {
          "description": "Reject an event as bad data and log to audit endpoint",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "reject_bad_data",
            "handlerDescription": "Reject an event as BAD_DATA. Records the rejection to ServiceNow audit endpoint with the reason and raw event, but does NOT create an incident. Use only when required fields are missing or garbled.",
            "readOnlyToolHint": false,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": true
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:tool-reject-bad-data"
            },
            "input": {
              "httpHeaders": "=$.httpHeaders",
              "arguments": "=$.arguments"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"correlationId\":{\"type\":\"string\"},\"reason\":{\"type\":\"string\"},\"timestamp\":{\"type\":\"string\"},\"appName\":{\"type\":\"string\"},\"appNode\":{\"type\":\"string\"},\"processName\":{\"type\":\"string\"},\"activityName\":{\"type\":\"string\"},\"errorCode\":{\"type\":\"string\"},\"errorMsg\":{\"type\":\"string\"}},\"required\":[\"correlationId\",\"reason\"]}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"correlationId\":{\"type\":\"string\"},\"reason\":{\"type\":\"string\"},\"timestamp\":{\"type\":\"string\"},\"appName\":{\"type\":\"string\"},\"appNode\":{\"type\":\"string\"},\"processName\":{\"type\":\"string\"},\"activityName\":{\"type\":\"string\"},\"errorCode\":{\"type\":\"string\"},\"errorMsg\":{\"type\":\"string\"}},\"required\":[\"correlationId\",\"reason\"]}"
              }
            }
          },
          "name": "tool-reject-bad-data"
        },
        {
          "description": "Append an occurrence to an existing incident",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "append_occurrence",
            "handlerDescription": "Append an occurrence to an existing open incident identified by sys_id. Bumps u_occurrence_count, updates u_last_seen, and appends a work note. Use when decision=DUPLICATE_OF with confidence above the floor.",
            "readOnlyToolHint": false,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": true
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:tool-append-occurrence"
            },
            "input": {
              "arguments": "=$.arguments",
              "httpHeaders": "=$.httpHeaders"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\"type\":\"object\",\"properties\":{\"sys_id\":{\"type\":\"string\"},\"occurrence_note\":{\"type\":\"string\"}},\"required\":[\"sys_id\"]}",
                "fe_metadata": "{\"type\":\"object\",\"properties\":{\"sys_id\":{\"type\":\"string\"},\"occurrence_note\":{\"type\":\"string\"}},\"required\":[\"sys_id\"]}"
              }
            }
          },
          "name": "tool-append-occurrence"
        },
        {
          "description": "Create a new incident in ServiceNow",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "create_incident",
            "handlerDescription": "Create a new ServiceNow incident for a BW6 error event. Pass the raw event plus triage metadata (decision_source, agent_confidence, reason, optional suggested_duplicate_of sys_id). Returns the created incident including sys_id.",
            "readOnlyToolHint": false,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": true
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:tool-create-incident"
            },
            "input": {
              "arguments": "=$.arguments",
              "httpHeaders": "=$.httpHeaders"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\"type\": \"object\", \"properties\": {\"short_description\": {\"type\": \"string\"}, \"description\": {\"type\": \"string\"}, \"u_stack_trace\": {\"type\": \"string\"}, \"u_error_code\": {\"type\": \"string\"}, \"u_app_name\": {\"type\": \"string\"}, \"u_app_node\": {\"type\": \"string\"}, \"u_process_name\": {\"type\": \"string\"}, \"u_activity_name\": {\"type\": \"string\"}, \"u_correlation_id\": {\"type\": \"string\"}, \"urgency\": {\"type\": \"string\"}, \"impact\": {\"type\": \"string\"}, \"u_decision_source\": {\"type\": \"string\"}, \"u_agent_confidence\": {\"type\": \"number\"}, \"u_triage_reason\": {\"type\": \"string\"}, \"u_suggested_duplicate_of\": {\"type\": \"string\"}, \"u_resolution_recommendation\": {\"type\": \"string\"}}, \"required\": [\"short_description\", \"u_error_code\", \"u_app_name\"]}",
                "fe_metadata": "{\"type\": \"object\", \"properties\": {\"short_description\": {\"type\": \"string\"}, \"description\": {\"type\": \"string\"}, \"u_stack_trace\": {\"type\": \"string\"}, \"u_error_code\": {\"type\": \"string\"}, \"u_app_name\": {\"type\": \"string\"}, \"u_app_node\": {\"type\": \"string\"}, \"u_process_name\": {\"type\": \"string\"}, \"u_activity_name\": {\"type\": \"string\"}, \"u_correlation_id\": {\"type\": \"string\"}, \"urgency\": {\"type\": \"string\"}, \"impact\": {\"type\": \"string\"}, \"u_decision_source\": {\"type\": \"string\"}, \"u_agent_confidence\": {\"type\": \"number\"}, \"u_triage_reason\": {\"type\": \"string\"}, \"u_suggested_duplicate_of\": {\"type\": \"string\"}, \"u_resolution_recommendation\": {\"type\": \"string\"}}, \"required\": [\"short_description\", \"u_error_code\", \"u_app_name\"]}"
              }
            }
          },
          "name": "tool-create-incident"
        },
        {
          "description": "Search open incidents by errorCode and appName within a window",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "search_past_resolutions",
            "handlerDescription": "Fetch past resolved ServiceNow incidents for a given errorCode. Returns up to 5 recently resolved incidents with their resolution recommendations — use to ground AI resolution advice in what actually worked before.",
            "readOnlyToolHint": false,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": true
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:tool-search-past-resolutions"
            },
            "input": {
              "arguments": "=$.arguments",
              "httpHeaders": "=$.httpHeaders"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\"type\": \"object\", \"properties\": {\"errorCode\": {\"type\": \"string\"}}, \"required\": [\"errorCode\"]}",
                "fe_metadata": "{\"type\": \"object\", \"properties\": {\"errorCode\": {\"type\": \"string\"}}, \"required\": [\"errorCode\"]}"
              }
            }
          },
          "name": "tool-search-past-resolutions"
        },
        {
          "description": "Fetch one incident by sys_id",
          "settings": {
            "handlerType": "Tool",
            "resourceUri": "",
            "handlerName": "update_incident_resolution",
            "handlerDescription": "Attach an AI resolution recommendation to an existing incident. Call this at the end of STEP 4 for NEW decisions. Pass sys_id of the created ticket and resolution as a JSON string.",
            "readOnlyToolHint": false,
            "destructiveToolHint": false,
            "idempotentToolHint": false,
            "openWorldToolHint": true
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:tool-update-incident-resolution"
            },
            "input": {
              "arguments": "=$.arguments",
              "httpHeaders": "=$.httpHeaders"
            },
            "output": {
              "response": "=$.response"
            }
          },
          "schemas": {
            "reply": {
              "response": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\"type\": \"object\", \"properties\": {\"sys_id\": {\"type\": \"string\"}, \"resolution\": {\"type\": \"string\"}}, \"required\": [\"sys_id\", \"resolution\"]}",
                "fe_metadata": "{\"type\": \"object\", \"properties\": {\"sys_id\": {\"type\": \"string\"}, \"resolution\": {\"type\": \"string\"}}, \"required\": [\"sys_id\", \"resolution\"]}"
              }
            }
          },
          "name": "tool-update-incident-resolution"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:tool-fetch-incident",
      "data": {
        "name": "tool-fetch-incident",
        "description": "Fetch one incident by sys_id",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "CallSN",
            "type": "label",
            "label": "StartActivity to CallSN"
          },
          {
            "id": 2,
            "from": "CallSN",
            "to": "Return",
            "type": "label",
            "label": "CallSN to Return"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "CallSN",
            "name": "CallSN",
            "description": "Call mock ServiceNow to fetch incident",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#rest",
              "input": {
                "enableASR": false,
                "asrDialog": "",
                "swagger": "",
                "authorization": false,
                "authorizationConn": "",
                "serviceName": "",
                "resourcePath": "",
                "Method": "GET",
                "Uri": "http://localhost:8081/api/now/table/incident/{sys_id}",
                "requestType": "application/json",
                "Use certificate for verification": false,
                "mutualAuth": false,
                "Client Certificate": "",
                "Client Key": "",
                "Server Certificate": "",
                "disableSSLVerification": false,
                "disableKeepAlives": false,
                "followRedirects": true,
                "Timeout": 0,
                "proxy": "",
                "host": "",
                "serviceUrl": "",
                "multipartForm": {},
                "pathParams": {
                  "mapping": {
                    "sys_id": "=coerce.toString($flow.arguments.sys_id)"
                  }
                },
                "headers": {
                  "mapping": {
                    "Accept": "application/json"
                  }
                },
                "dynamicRequestHeaders": {
                  "mapping": {}
                }
              },
              "output": {
                "configureResponseCodes": false,
                "throwError": false,
                "responseType": "application/json",
                "responseOutput": "JSON Object"
              },
              "schemas": {
                "input": {
                  "pathParams": {
                    "type": "json",
                    "value": "{\"type\":\"object\",\"properties\":{\"sys_id\":{\"type\":\"string\"}},\"required\":[]}",
                    "fe_metadata": "[{\"parameterName\":\"sys_id\",\"type\":\"string\"}]"
                  },
                  "headers": {
                    "type": "json",
                    "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Authorization\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                    "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}, {\"parameterName\":\"Authorization\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
                  },
                  "dynamicRequestHeaders": {
                    "type": "json",
                    "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"Header\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"},\"value\":{\"type\":\"string\"}},\"required\":[\"name\",\"value\"]}}}}",
                    "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"Header\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"},\"value\":{\"type\":\"string\"}},\"required\":[\"name\",\"value\"]}}}}"
                  }
                },
                "output": {
                  "responseBody": {
                    "type": "json",
                    "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{}}",
                    "fe_metadata": "{}"
                  },
                  "headers": {
                    "type": "json",
                    "value": "{\"type\":\"object\",\"properties\":{\"Accept\":{\"type\":\"string\",\"visible\":false},\"Accept-Charset\":{\"type\":\"string\",\"visible\":false},\"Accept-Encoding\":{\"type\":\"string\",\"visible\":false},\"Content-Type\":{\"type\":\"string\",\"visible\":false},\"Content-Length\":{\"type\":\"string\",\"visible\":false},\"Connection\":{\"type\":\"string\",\"visible\":false},\"Cookie\":{\"type\":\"string\",\"visible\":false},\"Pragma\":{\"type\":\"string\",\"visible\":false},\"Set-Cookie\":{\"type\":\"string\",\"visible\":false}},\"required\":[]}",
                    "fe_metadata": "[{\"parameterName\":\"Accept\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Charset\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Accept-Encoding\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Type\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Content-Length\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Connection\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Pragma\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false},{\"parameterName\":\"Set-Cookie\",\"type\":\"string\",\"repeating\":\"false\",\"required\":\"false\",\"visible\":false}]"
                  }
                }
              },
              "feSchemaMap": {}
            }
          },
          {
            "id": "Return",
            "name": "Return",
            "description": "Return tool response",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "response": "=$activity[CallSN].responseBody"
                }
              }
            }
          }
        ],
        "fe_metadata": "eyJTdGFydEFjdGl2aXR5Ijp7IngiOjUwLCJ5Ijo1MH0sIkNhbGxTTiI6eyJ4IjoyMjEsInkiOjQ4fSwiUmV0dXJuIjp7IngiOjQ5OSwieSI6NTF9fQ==",
        "metadata": {
          "input": [
            {
              "name": "arguments",
              "type": "object",
              "schema": {
                "type": "json",
                "value": "{\"sys_id\":{\"type\":\"string\"}}"
              }
            },
            {
              "name": "httpHeaders",
              "type": "params"
            }
          ],
          "output": [
            {
              "name": "response",
              "type": "object",
