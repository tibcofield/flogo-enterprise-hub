                      "$ref": "#/definitions/schema2"
                    }
                  }
                },
                "description": "Manually triggered flow that fetches sales data via MCP and returns analysis report.",
                "consumes": [
                  "application/json"
                ]
              }
            }
          },
          "definitions": {
