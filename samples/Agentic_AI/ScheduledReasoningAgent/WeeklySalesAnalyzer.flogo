  "properties": [
    {
      "name": "LLMClient.dataFetchPrompt",
      "type": "string",
      "value": "You are a data retrieval assistant. Your job is to gather comprehensive sales data for weekly analysis.\n\nUse the available MCP tools to retrieve:\n1. The weekly sales summary (total revenue, total orders, average order value)\n2. Team performance data (sales per team member)\n3. Product revenue breakdown (revenue per product category)\n4. Regional sales breakdown (performance by region)\n\nCall ALL FOUR tools to get complete data. Combine the results into a single, well-structured JSON summary. Do not analyze or interpret the data \u2014 just collect and organize it."
    },
    {
      "name": "LLMClient.analysisPrompt",
      "type": "string",
      "value": "You are a senior sales performance analyst. You have received the latest weekly sales data. Produce a comprehensive Weekly Sales Performance Report with the following sections:\n\n1. **Executive Summary** (2-3 sentences highlighting the most important takeaway)\n2. **Key Metrics** \u2014 present as a markdown table: Total Revenue, Total Orders, Average Order Value, Top Region, Top Product Category\n3. **Team Performance Analysis** \u2014 Rank by revenue, highlight top performer and underperformers\n4. **Product Revenue Insights** \u2014 Revenue by category with percentage of total, identify growth and declining categories\n5. **Regional Analysis** \u2014 Revenue by region with quarter-over-quarter trend, flag regions above or below target\n6. **Actionable Recommendations** (3-5 bullet points)\n7. **Risk Flags** \u2014 Any concerning patterns\n\nFormat the entire report in clean markdown. Use tables where appropriate. Be specific \u2014 cite actual numbers from the data."
    },
    {
      "name": "LLMClient.openai.LLM_Provider",
      "type": "string",
      "value": "OpenAI"
    },
    {
      "name": "LLMClient.openai.LLM_Model",
      "type": "string",
      "value": "gpt-4o"
    },
    {
      "name": "LLMClient.APIKey",
      "type": "string",
      "value": "SECRET:bT8pGZLwqgxrjuBc8L2hRWoWlA=="
    },
    {
      "name": "LLMClient.htmlFormatPrompt",
      "type": "string",
      "value": "You are an HTML report formatter. Convert the provided sales analysis report into a professional, visually appealing HTML document.\n\nRequirements:\n1. Create a complete HTML5 document with all styles inline (no external CSS)\n2. Use a clean, professional color scheme: navy headers (#1a365d), light gray background (#f7fafc), white content cards\n3. Convert all markdown tables into styled HTML tables with alternating row colors\n4. Add a header banner with the report title and generation date\n5. Use appropriate icons or color indicators for metrics:\n   - Green (#38a169) for positive trends/growth\n   - Red (#e53e3e) for negative trends/risks\n   - Blue (#3182ce) for neutral metrics\n6. Format numbers with proper separators and currency symbols\n7. Add a professional footer with \"Generated by TIBCO Flogo Scheduled Reasoning Agent\"\n8. Make the document print-friendly (suitable for Save as PDF)\n9. Use responsive design that looks good at any width\n10. Wrap each report section in a card-style container with subtle shadows\n\nOutput ONLY the complete HTML document, starting with <!DOCTYPE html> and ending with </html>. No markdown, no explanation."
    },
    {
      "name": "Report.outputDir",
      "type": "string",
      "value": "./reports"
    },
    {
      "name": "Email.SMTP.Server",
      "type": "string",
      "value": "smtp.gmail.com"
    },
    {
      "name": "Email.SMTP.Port",
      "type": "string",
      "value": "587"
    },
    {
      "name": "Email.SMTP.Username",
      "type": "string",
      "value": "test@gmail.com"
    },
    {
      "name": "Email.sender",
      "type": "string",
      "value": "test@gmail.com"
    },
    {
      "name": "Email.recipients",
      "type": "string",
      "value": "test@gmail.com"
    },
    {
      "name": "Email.SMTP.Password",
      "type": "string",
      "value": "SECRET:2VlDHH3o4YwX8AFIfw2V2u6+9w=="
    }
  ],
