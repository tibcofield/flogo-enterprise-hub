          {
            "id": "ReturnReport",
            "name": "ReturnReport",
            "description": "Returns the analysis report as HTTP 200 JSON.",
            "activity": {
              "ref": "#actreturn",
              "settings": {
                "mappings": {
                  "code": 200,
                  "data": {
                    "mapping": {
                      "report": "=$activity[AnalyzeAndReport].response",
                      "html_report": "=$activity[FormatHTMLReport].response",
                      "report_file": "=$activity[SaveReport].output.fileMetadata.fullPath",
                      "triggered_by": "manual"
                    }
                  }
                }
              }
            }
          }
