          {
            "id": "EmailReport",
            "name": "EmailReport",
            "description": "Send HTML report via email to stakeholders.",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#sendmail",
              "input": {
                "Server": "=$property[\"Email.SMTP.Server\"]",
                "Port": 587,
                "authorizationType": "Basic",
                "Username": "=$property[\"Email.SMTP.Username\"]",
                "Password": "=$property[\"Email.SMTP.Password\"]",
                "authorizationConn": "",
                "Connection Security": "TLS",
                "serverCertificate": "",
                "message_content_type": "text/html",
                "sender": "=$property[\"Email.sender\"]",
                "recipients": "=$property[\"Email.recipients\"]",
                "cc_recipients": "",
                "bcc_recipients": "",
                "reply_to": "",
                "subject": "Weekly Sales Performance Report",
                "message": "=$activity[FormatHTMLReport].response",
                "attachments": {
                  "mapping": [
                    {
                      "file": "=$activity[FormatHTMLReport].response",
                      "filename": "weekly-sales-report.html",
                      "base64EncodedContents": false
                    }
                  ]
                }
              },
              "schemas": {
                "input": {
                  "attachments": {
                    "type": "json",
                    "value": "{\"$schema\":\"http://json-schema.org/draft-07/schema#\",\"items\":{\"properties\":{\"file\":{\"type\":\"string\"},\"filename\":{\"type\":\"string\"},\"base64EncodedContents\":{\"type\":\"boolean\"}},\"required\":[\"file\"],\"type\":\"object\"},\"type\":\"array\"}",
                    "fe_metadata": "{\"$schema\":\"http://json-schema.org/draft-07/schema#\",\"items\":{\"properties\":{\"file\":{\"type\":\"string\"},\"filename\":{\"type\":\"string\"},\"base64EncodedContents\":{\"type\":\"boolean\"}},\"required\":[\"file\"],\"type\":\"object\"},\"type\":\"array\"}"
